{
  "name": "recruiting-portfolio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/generate-public-artifacts.mjs && astro dev --host 127.0.0.1",
    "build": "node scripts/validate-claims.mjs && node scripts/generate-public-artifacts.mjs && astro check && astro build && node scripts/generate-resume-pdf.mjs && node scripts/validate-dist.mjs",
    "preview": "astro preview --host 127.0.0.1",
    "test": "npm run build && npm run test:e2e",
    "test:content": "node scripts/validate-dist.mjs",
    "test:e2e": "playwright test",
    "check": "astro check && npm run build",
    "indexnow": "node scripts/submit-indexnow.mjs"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/react": "^6.0.1",
    "@lucide/astro": "^1.24.0",
    "astro": "^7.0.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "esbuild": "0.28.1"
  }
}
