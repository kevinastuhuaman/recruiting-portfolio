<script>
  import { capturePortfolioEvent, classifyPortfolioInteraction } from "../lib/portfolioEvents";

  const earlyClickHandler = (event: MouseEvent) => {
    if (!(event.target instanceof Element)) return;
    const classified = classifyPortfolioInteraction(event.target);
    if (classified) capturePortfolioEvent(classified.event, classified.properties);
  };
  window.__portfolioEarlyClickHandler = earlyClickHandler;
  document.addEventListener("click", earlyClickHandler, { capture: true });

  const startAnalytics = () => {
    void import("../lib/portfolioAnalytics").then(({ initializePortfolioAnalytics }) => {
      initializePortfolioAnalytics(
        import.meta.env.PUBLIC_POSTHOG_KEY,
        import.meta.env.PUBLIC_POSTHOG_HOST || "https://us.i.posthog.com",
        import.meta.env.PUBLIC_POSTHOG_ALLOWED_HOST || "portfolio.kevinastuhuaman.com",
      );
    }).catch(() => undefined);
  };

  if (typeof window.requestIdleCallback === "function") {
    window.requestIdleCallback(startAnalytics, { timeout: 3_000 });
  } else {
    globalThis.setTimeout(startAnalytics, 1_500);
  }
</script>
