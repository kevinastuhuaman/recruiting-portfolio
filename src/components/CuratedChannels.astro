---
import { ArrowUpRight, Hammer, Headphones, PenLine } from "@lucide/astro";
import { links } from "../data/site.js";
import SocialMark from "./SocialMark.astro";

const channels = [
  {
    id: "work",
    title: "Work",
    description: "What I ship and how I think about products.",
    icon: Hammer,
    ariaLabel: "Kevin's work profiles",
    links: [
      { label: "GitHub", href: links.github, destination: "github" },
      { label: "LinkedIn", href: links.linkedin, destination: "linkedin" },
    ],
  },
  {
    id: "ideas",
    title: "Ideas & perspective",
    description: "Writing, unfinished thoughts, and life beyond work.",
    icon: PenLine,
    ariaLabel: "Kevin's writing and personal pages",
    links: [
      { label: "Newsletter", href: links.writing, destination: "newsletter" },
      { label: "X", href: links.x, destination: "x" },
      { label: "Personal story", href: links.personalStory, destination: "personal_story" },
    ],
  },
  {
    id: "watch-listen",
    title: "Watch & listen",
    description: "Conversations with builders and my personal finance YouTube channel.",
    icon: Headphones,
    ariaLabel: "Kevin's podcast and video channel",
    links: [
      { label: "Podcast", href: links.podcast, destination: "podcast" },
      { label: "YouTube", href: links.youtube, destination: "youtube" },
    ],
  },
];
---

<section id="channels" class="curated-channels" aria-labelledby="channels-title">
  <header class="channels-heading">
    <div>
      <p class="eyebrow">Beyond the portfolio</p>
      <h2 id="channels-title">Follow the thread.</h2>
    </div>
    <p>Choose the part of Kevin's world you want to explore next.</p>
  </header>

  <div class="channels-grid">
    {channels.map((channel) => {
      const Icon = channel.icon;
      return (
        <section class="channel" aria-labelledby={`channel-${channel.id}`}>
          <Icon class="channel-icon" aria-hidden="true" size={25} stroke-width={1.7} />
          <h3 id={`channel-${channel.id}`}>{channel.title}</h3>
          <p>{channel.description}</p>
          <nav aria-label={channel.ariaLabel}>
            {channel.links.map((link) => (
              <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                data-portfolio-channel={channel.id}
                data-portfolio-destination={link.destination}
              >
                <span class="channel-link-label"><SocialMark name={link.label} /><span>{link.label}</span></span>
                <ArrowUpRight aria-hidden="true" size={17} />
              </a>
            ))}
          </nav>
        </section>
      );
    })}
  </div>
</section>

<style>
  .curated-channels {
    padding: clamp(72px, 8vw, 112px) clamp(24px, 5vw, 72px);
    border-top: 1px solid #171717;
    background: #f6f7f8;
  }

  .channels-heading {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.72fr);
    max-width: 1200px;
    margin-inline: auto;
    padding-bottom: 36px;
    align-items: end;
    gap: clamp(32px, 7vw, 96px);
  }

  .channels-heading h2 {
    margin-bottom: 0;
    font-size: clamp(3rem, 5vw, 5rem);
    letter-spacing: -0.045em;
  }

  .channels-heading > p {
    max-width: 430px;
    margin-bottom: 5px;
    color: #55595f;
    font-size: 1.05rem;
  }

  .channels-grid {
    display: grid;
    max-width: 1200px;
    margin-inline: auto;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border-top: 1px solid #171717;
    border-bottom: 1px solid #171717;
  }

  .channel {
    display: grid;
    min-width: 0;
    min-height: 330px;
    padding: 30px;
    grid-template-rows: 32px 82px 108px auto;
  }

  .channel + .channel {
    border-left: 1px solid #171717;
  }

  .channel-icon {
    color: #55595f;
  }

  .channel h3 {
    margin: 0;
    font-size: clamp(1.55rem, 2.4vw, 2rem);
    align-self: start;
    letter-spacing: -0.02em;
  }

  .channel > p {
    max-width: 330px;
    margin: 0;
    color: #55595f;
    font-size: 0.98rem;
  }

  .channel nav {
    align-self: start;
    width: 100%;
  }

  .channel a {
    display: flex;
    min-height: 46px;
    padding: 11px 0;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    border-top: 1px solid #c9c9c3;
    font-weight: 720;
    text-decoration: none;
  }

  .channel-link-label { display: inline-flex; align-items: center; gap: 10px; }
  .channel-link-label :global(svg) { width: 17px; height: 17px; color: #55595f; }

  .channel a svg {
    flex: 0 0 auto;
    transition: transform 160ms ease;
  }

  .channel a:hover span,
  .channel a:focus-visible span {
    text-decoration: underline;
    text-underline-offset: 0.25em;
  }

  .channel a:hover svg,
  .channel a:focus-visible svg {
    transform: translate(2px, -2px);
  }

  @media (max-width: 820px) {
    .channels-heading,
    .channels-grid {
      grid-template-columns: 1fr;
    }

    .channels-heading {
      gap: 16px;
    }

    .channels-heading > p {
      margin-bottom: 0;
    }

    .channel {
      display: block;
      min-height: 0;
      padding: 30px 0;
    }

    .channel + .channel {
      border-top: 1px solid #171717;
      border-left: 0;
    }

    .channel-icon {
      display: block;
      margin-bottom: 28px;
    }

    .channel > p {
      margin: 14px 0 28px;
    }
  }

  @media (max-width: 480px) {
    .curated-channels {
      padding-inline: 22px;
    }

    .channels-heading {
      padding-bottom: 30px;
    }

    .channels-heading h2 {
      font-size: clamp(2.75rem, 14vw, 3.5rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .channel a svg {
      transition: none;
    }
  }
</style>
