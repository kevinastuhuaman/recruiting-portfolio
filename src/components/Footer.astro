---
import { ArrowUpRight, BriefcaseBusiness, CodeXml, Copy, FileText } from "@lucide/astro";
import { links, site } from "../data/site.js";
---

<footer id="contact" class="site-footer">
  <div class="footer-primary">
    <div>
      <p class="eyebrow">Start a conversation</p>
      <h2>Building an AI product where judgment matters?</h2>
    </div>
    <div class="footer-actions">
      <a class="button button-light" href={links.linkedin}>
        <BriefcaseBusiness aria-hidden="true" size={18} /> LinkedIn <ArrowUpRight aria-hidden="true" size={16} />
      </a>
      <button class="button button-outline-light footer-copy-email" type="button" data-copy-email={site.email}>
        <Copy aria-hidden="true" size={18} /> Copy email
      </button>
      <a class="button button-outline-light" href="/resume/">
        <FileText aria-hidden="true" size={18} /> View resume
      </a>
    </div>
  </div>
  <div class="footer-contact-note">
    <span>{site.email}</span>
    <span class="footer-copy-status" aria-live="polite"></span>
  </div>
  <div class="footer-meta">
    <span>Kevin Astuhuaman | Bay Area</span>
    <nav aria-label="Supporting links">
      <a href="/about/">About</a>
      <a href={links.github}><CodeXml aria-hidden="true" size={16} /> GitHub</a>
      <a href="/ask/">Ask Kevin</a>
      <a href="/proof/">Evidence</a>
      <a href="/privacy/">Privacy</a>
      <a href="/llms.txt">llms.txt</a>
      <a href="/profile.json">Profile JSON</a>
    </nav>
  </div>
</footer>

<script>
  const copyButton = document.querySelector<HTMLButtonElement>("[data-copy-email]");
  const copyStatus = document.querySelector<HTMLElement>(".footer-copy-status");
  let statusTimer: number | undefined;

  copyButton?.addEventListener("click", async () => {
    const email = copyButton.dataset.copyEmail;
    if (!email) return;

    try {
      await navigator.clipboard.writeText(email);
      if (copyStatus) copyStatus.textContent = "Email copied";
      window.clearTimeout(statusTimer);
      statusTimer = window.setTimeout(() => {
        if (copyStatus) copyStatus.textContent = "";
      }, 2200);
    } catch {
      window.prompt("Copy Kevin's email", email);
    }
  });
</script>
