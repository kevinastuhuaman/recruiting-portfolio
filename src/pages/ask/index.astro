---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PortfolioAssistant from "../../components/portfolio/PortfolioAssistant";
import { claimsById } from "../../data/claims.js";
---

<BaseLayout
  title="Ask anything about Kevin | Chat and Voice"
  description="Ask Kevin's AI assistant about his work, product decisions, and experience through Chat or Voice."
  path="/ask/"
  noindex={true}
>
  <div class="ask-page">
    <header class="ask-hero">
      <p class="eyebrow">Kevin's AI assistant</p>
      <h1>Ask anything about Kevin.</h1>
      <p>Explore his work in Chat or have a voice conversation.</p>
    </header>

    <PortfolioAssistant client:only="react">
      <section slot="fallback" class="assistant-placeholder" aria-label="Portfolio assistant loading">
        <p>Interactive Chat and Voice load only when JavaScript is available. The static cited answers continue below.</p>
      </section>
    </PortfolioAssistant>

    <section class="faq-section" aria-labelledby="fallback-title">
      <header>
        <p class="eyebrow">Static, cited fallback</p>
        <h2 id="fallback-title">Five answers without the model.</h2>
        <p>These answers stay available if JavaScript, Chat, Voice, or the backend is unavailable.</p>
      </header>
      <div class="faq-list">
        <details open>
          <summary>What kind of product manager is Kevin?</summary>
          <p>Kevin is an AI Product Manager focused on applied AI, agent products, and technical platforms. His evidence spans an observability prototype at PayPal Checkout, hands-on Trackly building, AI strategy at Berkeley Haas, and six years of regulated product progression at BCP.</p>
          <a href="/resume/">Resume and role lenses</a>
        </details>
        <details>
          <summary>What did Kevin build at PayPal?</summary>
          <p>{claimsById["paypal-detection"].statement}</p>
          <a href="/projects/paypal-ai-observability/">PayPal case study</a>
        </details>
        <details>
          <summary>How does Trackly prove hands-on execution?</summary>
          <p>Kevin built and operates Trackly across web, iOS, macOS, CLI, MCP, chat, and voice. The case study shows direct-source monitoring, explainable matching, false-zero recovery, release boundaries, and human approval before consequential browser actions.</p>
          <a href="/projects/trackly/">Trackly case study</a>
        </details>
        <details>
          <summary>What did Kevin do with Berkeley and MoBagel?</summary>
          <p>Kevin contributed discovery, competitive research, a high-fidelity Figma prototype, roadmap, business model, pricing, and United States go-to-market recommendations for an AI adoption challenge.</p>
          <a href="/projects/berkeley-mobagel-ai-gtm/">Berkeley and MoBagel case study</a>
        </details>
        <details>
          <summary>What leadership evidence comes from BCP?</summary>
          <p>Kevin progressed through four product roles. {claimsById["bcp-team"].statement} {claimsById["bcp-digital-growth"].statement}</p>
          <a href="/projects/smb-fintech-bcp-credicorp/">BCP and Credicorp case study</a>
        </details>
      </div>
      <noscript><p class="no-script-note">Interactive questions require JavaScript. The five cited answers above remain fully available.</p></noscript>
    </section>
  </div>
</BaseLayout>

<style is:global>
  .ask-page { max-width: 1200px; margin: 0 auto; padding: 76px 28px 120px; }
  .ask-hero { display: grid; grid-template-columns: minmax(0,1.3fr) minmax(260px,.7fr); gap: 24px 54px; align-items: end; padding: 42px 0 58px; border-bottom: 1px solid var(--ink); }
  .ask-hero .eyebrow { grid-column: 1 / -1; }
  .ask-hero h1 { max-width: 820px; margin: 0; font-size: clamp(3.4rem,7vw,6.9rem); line-height: .92; letter-spacing: -.055em; text-wrap: balance; }
  .ask-hero > p:not(.eyebrow) { margin: 0; color: var(--muted); font-size: 1.08rem; line-height: 1.65; }
  .assistant-shell { margin-top: 68px; border: 1px solid var(--ink); background: #fff; box-shadow: 16px 18px 0 rgba(39,23,71,.1); }
  .assistant-placeholder { display: grid; min-height: 680px; margin-top: 68px; padding: 32px; place-items: center; border: 1px solid var(--ink); background: #fff; color: var(--muted); text-align: center; box-shadow: 16px 18px 0 rgba(39,23,71,.1); }
  .assistant-tabs { display: grid; grid-template-columns: 1fr 1fr; border-bottom: 1px solid var(--ink); }
  .assistant-tabs button { display: flex; min-height: 68px; padding: 14px 20px; align-items: center; justify-content: space-between; border: 0; border-right: 1px solid var(--ink); background: #fff; font-weight: 750; cursor: pointer; }
  .assistant-tabs button:last-child { border-right: 0; }
  .assistant-tabs button[aria-selected="true"] { background: var(--trackly-dark); color: #fff; }
  .chat-panel { display: grid; grid-template-columns: minmax(300px,.68fr) minmax(0,1.32fr); min-height: 650px; }
  .chat-panel > header { padding: 34px; border-right: 1px solid var(--ink); }
  .chat-panel > header h2 { margin: 42px 0 18px; font-size: clamp(2.35rem,3.7vw,3.75rem); line-height: .98; letter-spacing: -.04em; overflow-wrap: normal; text-wrap: balance; }
  .chat-panel > header > p:last-child { color: var(--muted); }
  .chat-messages { min-height: 410px; max-height: 560px; padding: 34px; overflow-y: auto; }
  .chat-empty { display: grid; gap: 10px; }
  .chat-empty strong { margin-bottom: 18px; color: var(--muted); font-size: .78rem; text-transform: uppercase; letter-spacing: .08em; }
  .chat-empty button { padding: 18px; border: 1px solid var(--line); border-radius: 4px; background: #f8f7fb; text-align: left; cursor: pointer; }
  .chat-empty button:hover { border-color: var(--trackly); }
  .chat-message { max-width: 82%; margin-bottom: 22px; }
  .chat-message.user { margin-left: auto; padding: 16px 18px; border-radius: 4px; background: #ece9f7; }
  .chat-message.assistant { max-width: 88%; }
  .chat-message-label { display: inline-flex; align-items: center; gap: 8px; color: var(--muted); font-size: .68rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; }
  .chat-message p { margin: 7px 0 0; white-space: pre-wrap; }
  .assistant-trace { width: 18px; height: 18px; flex: 0 0 auto; fill: none; stroke: currentColor; stroke-width: 1.55; stroke-linecap: round; stroke-linejoin: round; }
  .assistant-trace circle { fill: currentColor; stroke: none; transform-box: fill-box; }
  .chat-activity { display: inline-flex; position: relative; min-height: 44px; padding: 10px 14px; align-items: center; gap: 10px; overflow: hidden; border: 1px solid var(--line); border-radius: 999px; background: rgba(248,247,251,.88); color: var(--muted); }
  .chat-activity::after { position: absolute; inset: 0; background: linear-gradient(100deg, transparent 20%, rgba(128,86,245,.11) 48%, transparent 76%); content: ""; transform: translateX(-100%); animation: activity-scan 1.7s ease-in-out infinite; }
  .chat-activity > * { position: relative; z-index: 1; }
  .chat-activity span { font-size: .76rem; font-weight: 650; letter-spacing: .01em; }
  .chat-activity .assistant-trace { color: var(--trackly); }
  .assistant-trace.is-animated circle:first-of-type { animation: trace-node 1.4s ease-in-out infinite; }
  .assistant-trace.is-animated circle:last-of-type { animation: trace-node 1.4s .28s ease-in-out infinite; }
  .chat-citations { grid-column: 2; display: flex; padding: 18px 34px; flex-wrap: wrap; gap: 8px 14px; border-top: 1px solid var(--line); font-size: .78rem; }
  .chat-citations strong { width: 100%; color: var(--muted); text-transform: uppercase; letter-spacing: .07em; }
  .chat-citations a { padding: 5px 8px; border: 1px solid var(--line); border-radius: 999px; text-decoration: none; }
  .chat-feedback { grid-column: 2; display: flex; padding: 12px 34px; align-items: center; flex-wrap: wrap; gap: 8px; border-top: 1px solid var(--line); color: var(--muted); font-size: .76rem; }
  .chat-feedback span { margin-right: 4px; }
  .chat-feedback button { padding: 6px 10px; border: 1px solid var(--line); border-radius: 999px; background: #fff; color: var(--ink); cursor: pointer; }
  .chat-feedback button:disabled { color: var(--muted); cursor: default; opacity: .65; }
  .chat-form { grid-column: 2; padding: 24px 34px 18px; border-top: 1px solid var(--ink); }
  .chat-form > label { display: block; margin-bottom: 8px; font-weight: 700; }
  .chat-form > div { display: grid; grid-template-columns: 1fr auto; border: 1px solid var(--ink); }
  .chat-form textarea { min-width: 0; padding: 14px; resize: vertical; border: 0; background: transparent; }
  .chat-form button { min-width: 100px; border: 0; border-left: 1px solid var(--ink); background: var(--signal); font-weight: 750; cursor: pointer; }
  .chat-form button:disabled { background: #ecece8; color: #8b8b87; cursor: not-allowed; }
  .chat-form > p { margin: 8px 0 0; color: var(--muted); font-size: .72rem; }
  .assistant-status { grid-column: 2; padding: 0 34px 22px; color: var(--muted); font-size: .74rem; }
  .assistant-status.sr-only { position: absolute; width: 1px; height: 1px; margin: -1px; padding: 0; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0; }
  .voice-panel { display: grid; grid-template-columns: 1fr 1fr; min-height: 660px; background: #15111e; color: #fff; }
  .voice-orb-wrap { display: grid; min-height: 560px; place-items: center; border-right: 1px solid rgba(255,255,255,.22); background: radial-gradient(circle at 50% 50%,rgba(128,86,245,.12),transparent 58%); }
  .portfolio-voice-orb { display: block; border-radius: 50%; }
  .portfolio-voice-orb-intro { width: 260px; height: 260px; }
  .portfolio-voice-orb-active { width: 300px; height: 300px; }
  .portfolio-voice-orb-fallback { background: radial-gradient(circle at 35% 35%, rgba(139,92,246,.95), rgba(76,194,233,.6) 45%, rgba(16,20,153,.9) 100%); }
  .voice-copy { display: flex; padding: 48px; flex-direction: column; justify-content: center; align-items: flex-start; }
  .voice-copy h2 { margin: 18px 0 22px; font-size: clamp(2.7rem,5vw,5rem); line-height: .92; letter-spacing: -.055em; }
  .voice-copy > p:not(.eyebrow,.voice-state,.voice-error) { color: rgba(255,255,255,.68); }
  .voice-primary, .voice-secondary, .voice-controls button { min-height: 48px; padding: 11px 17px; border: 1px solid var(--ink); border-radius: 4px; font-weight: 700; cursor: pointer; }
  .voice-primary { width: 100%; margin-top: 22px; border-color: var(--signal); background: var(--signal); color: var(--ink); }
  .voice-secondary { margin-top: 12px; border-color: rgba(255,255,255,.55); background: transparent; color: #fff; }
  .voice-copy.active { align-items: center; text-align: center; }
  .voice-state { font-size: clamp(1.8rem,4vw,3.4rem); font-weight: 750; letter-spacing: -.04em; }
  .voice-error { color: #ff9b9b; }
  .voice-controls { display: flex; flex-wrap: wrap; justify-content: center; gap: 10px; }
  .voice-controls button { border-color: rgba(255,255,255,.52); background: #fff; color: var(--ink); }
  .voice-controls .voice-end-call { background: transparent; color: #fff; }
  .voice-sources { display: grid; width: 100%; gap: 8px; margin-top: 28px; padding-top: 20px; border-top: 1px solid rgba(255,255,255,.22); text-align: left; }
  .voice-sources a { font-size: .84rem; }
  .faq-section { display: grid; grid-template-columns: .62fr 1.38fr; gap: 54px; margin-top: 100px; padding-top: 68px; border-top: 1px solid var(--ink); }
  .faq-section header h2 { margin: 42px 0 16px; font-size: clamp(2.5rem,5vw,4.8rem); line-height: .95; letter-spacing: -.05em; }
  .faq-section header > p:last-child { color: var(--muted); }
  .faq-list details { border-bottom: 1px solid var(--ink); }
  .faq-list summary { padding: 24px 0; font-weight: 750; cursor: pointer; }
  .faq-list details p { color: var(--muted); }
  .faq-list details a { display: inline-block; margin: 0 0 24px; font-weight: 700; }
  .no-script-note { grid-column: 1 / -1; padding: 18px; background: var(--signal); }
  @keyframes activity-scan { 55%,100% { transform: translateX(100%); } }
  @keyframes trace-node { 0%,100% { opacity: .32; transform: scale(.72); transform-origin: center; } 50% { opacity: 1; transform: scale(1); } }
  @media (max-width: 820px) {
    .ask-page { padding: 52px 18px 88px; }
    .ask-hero, .chat-panel, .voice-panel, .faq-section { grid-template-columns: 1fr; }
    .chat-panel > header, .voice-orb-wrap { border-right: 0; border-bottom: 1px solid var(--ink); }
    .chat-messages { min-height: 360px; }
    .chat-citations, .chat-feedback, .chat-form, .assistant-status { grid-column: 1; }
    .voice-orb-wrap { min-height: 390px; }
    .voice-copy { padding: 34px 24px 44px; }
    .assistant-placeholder { min-height: 760px; }
  }
  @media (max-width: 520px) {
    .assistant-tabs button { align-items: flex-start; flex-direction: column; }
    .chat-panel > header, .chat-messages, .chat-form { padding-inline: 20px; }
    .chat-message { max-width: 94%; }
    .chat-form > div { grid-template-columns: 1fr; }
    .chat-form button { min-height: 48px; border-top: 1px solid var(--ink); border-left: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .chat-activity::after, .assistant-trace.is-animated circle { animation: none !important; }
  }
</style>
