---
import { ArrowDown, ArrowUpRight, Download, Mail } from "@lucide/astro";
import InvestigationWorkbench from "../components/InvestigationWorkbench.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { experience, links, projects, publicClaims, site } from "../data/site.js";

const paypal = projects.find((project) => project.id === "paypal") ?? projects[0];
const trackly = projects.find((project) => project.id === "trackly") ?? projects[1];
const mobagel = projects.find((project) => project.id === "mobagel") ?? projects[2];
const bcp = projects.find((project) => project.id === "bcp") ?? projects[3];
const inventory = publicClaims.find((claim) => claim.id === "trackly-inventory") ?? publicClaims[0];
const appStore = publicClaims.find((claim) => claim.id === "trackly-app-store") ?? publicClaims[1];
const paypalClaim = publicClaims.find((claim) => claim.id === "paypal-detection") ?? publicClaims[2];
---

<BaseLayout
  title="Kevin Astuhuaman | AI Product Manager"
  description={site.description}
  path="/"
  pageType="profile"
>
  <section class="home-hero" aria-labelledby="home-title">
    <div class="hero-scene" aria-hidden="true">
      <div class="hero-console">
        <div class="scene-toolbar"><span>AI Investigation Workbench</span><b>Read-only</b></div>
        <div class="scene-question">Why did checkout completion fall after payment selection?</div>
        <div class="scene-progress"><i></i><i></i><i></i><i></i></div>
        <div class="scene-columns">
          <div>
            <span>Evidence plan</span>
            <strong>Funnel movement</strong>
            <strong>Behavioral sessions</strong>
            <strong>Service health</strong>
            <strong>Issue history</strong>
          </div>
          <div>
            <span>Human decision</span>
            <p>Observation</p>
            <em>Completion fell in one synthetic cohort.</em>
            <p>Unknown</p>
            <em>One diagnostic source is unavailable.</em>
          </div>
        </div>
      </div>
    </div>
    <div class="hero-content">
      <p class="eyebrow">AI Product Manager | Berkeley Haas MBA '26</p>
      <h1 id="home-title">Kevin<br />Astuhuaman</h1>
      <p class="hero-thesis">
        Most recently, I built agentic observability prototypes at PayPal Checkout. Seven years building products and enjoying every minute of it.
      </p>
      <p class="hero-support">I also built Trackly across web, iOS, macOS, CLI, MCP, chat, and voice, and led digital-first financial products at Banco de Credito BCP.</p>
      <div class="button-row">
        <a class="button button-light" href="/projects/paypal-ai-observability/">
          See PayPal work <ArrowUpRight aria-hidden="true" size={17} />
        </a>
        <a class="button button-ghost" href="/resume/">
          <Download aria-hidden="true" size={17} /> Resume
        </a>
        <a class="button button-ghost" href="/contact/">
          <Mail aria-hidden="true" size={17} /> Contact
        </a>
      </div>
    </div>
    <a class="hero-next" href="#work">
      <ArrowDown aria-hidden="true" size={17} /> Explore the investigation
    </a>
    <p class="hero-proof">PayPal work shown as a public-safe reconstruction</p>
  </section>

  <section class="proof-band" aria-label="Selected proof">
    <div class="section-shell proof-band-inner">
      <div>
        <strong>PayPal Checkout</strong>
        <span>{paypalClaim.short}</span>
      </div>
      <div>
        <strong>Berkeley Haas</strong>
        <span>MBA '26 · AI product strategy and prototyping</span>
      </div>
      <div>
        <strong>Trackly</strong>
        <span>App Store · Web · iOS · macOS · CLI/MCP</span>
      </div>
      <div>
        <strong>BCP / Credicorp</strong>
        <span>Lead Product Manager · 9 direct reports</span>
      </div>
    </div>
  </section>

  <section id="work" class="section-pad paypal-story">
    <div class="section-shell story-heading">
      <div>
        <p class="eyebrow">Recent enterprise AI</p>
        <h2>At PayPal, I made fragmented checkout evidence usable.</h2>
      </div>
      <p class="lede">
        The product problem was not a lack of dashboards. It was that a PM needed expertise across many tools and teams to explain what users experienced. I focused the workflow on one accountable job: turn a symptom into evidence, a bounded hypothesis, and a human-owned next action.
      </p>
    </div>

    <div class="section-shell paypal-metrics" aria-label="PayPal internship project scope and results">
      <div><strong>15+</strong><span>diagnostic tools in the project landscape</span></div>
      <div><strong>75%</strong><span>faster issue detection in the internship prototype workflow</span></div>
      <div><strong>5x</strong><span>faster triage in the auto-triage proof of concept</span></div>
    </div>

    <div class="section-shell workbench-stage">
      <InvestigationWorkbench headingLevel="h3" />
    </div>

    <div class="section-shell decisions-home paypal-decisions">
      <article>
        <span>01</span>
        <h3>Start with the investigation job</h3>
        <p>The success measure was faster, better-supported diagnosis, not whether an agent could produce a fluent answer.</p>
      </article>
      <article>
        <span>02</span>
        <h3>Separate evidence from inference</h3>
        <p>The interface labels observations, hypotheses, contradictions, and missing data so uncertainty remains visible.</p>
      </article>
      <article>
        <span>03</span>
        <h3>Keep ownership human</h3>
        <p>The agent may gather and structure evidence. A person decides whether the escalation is ready and who owns the action.</p>
      </article>
    </div>

    <div class="section-shell work-cta">
      <a class="text-link" href={paypal.href}>Read the complete PayPal case <ArrowUpRight aria-hidden="true" size={18} /></a>
      <span>Prototype and POC results · not a PayPal-wide production claim</span>
    </div>
  </section>

  <section id="trackly" class="section-pad trackly-story">
    <div class="section-shell story-heading">
      <div>
        <p class="eyebrow">Hands-on builder proof</p>
        <h2>Trackly started with a timing problem.</h2>
      </div>
      <p class="lede">
        Strong roles were appearing on company career pages before job boards. I built the direct signal first, then the quality system, matching, agents, and native surfaces needed to make that signal useful every day.
      </p>
    </div>

    <div class="section-shell product-stage">
      <img
        src={trackly.image}
        width="1440"
        height="1000"
        loading="lazy"
        alt="Trackly homepage with direct company career-page monitoring and public inventory counts"
      />
      <div class="product-stage-caption">
        <span>Live product capture</span>
        <span>{inventory.statement}</span>
      </div>
    </div>

    <div class="section-shell decisions-home">
      <article>
        <span>01</span>
        <h3>Own the source</h3>
        <p>Monitor company career pages directly instead of waiting for an aggregator. The product competes on earlier, more trustworthy signal.</p>
      </article>
      <article>
        <span>02</span>
        <h3>Design for failure</h3>
        <p>Career pages drift and parsers break. False-zero canaries, stale-job guards, deduplication, and eval review are product features, not backend cleanup.</p>
      </article>
      <article>
        <span>03</span>
        <h3>One system, many interfaces</h3>
        <p>Web, iOS, macOS, CLI, MCP, chat, and voice share the same product logic while respecting what each interface does best.</p>
      </article>
    </div>

    <div class="section-shell work-cta">
      <a class="text-link" href={trackly.href}>Read the complete Trackly case <ArrowUpRight aria-hidden="true" size={18} /></a>
      <span>{appStore.short}</span>
    </div>
  </section>

  <section class="selected-work section-pad" aria-labelledby="selected-title">
    <div class="section-shell section-intro">
      <p class="eyebrow">Strategy and scale</p>
      <h2 id="selected-title">From AI adoption to regulated operating scale.</h2>
    </div>
    <div class="section-shell work-pair">
      <a class="work-card mobagel-card" href={mobagel.href}>
        <div>
          <p class="eyebrow">{mobagel.eyebrow}</p>
          <h3>{mobagel.name}</h3>
          <p>{mobagel.thesis}</p>
        </div>
        <span>{mobagel.proof} <ArrowUpRight aria-hidden="true" size={18} /></span>
      </a>
      <a class="work-card bcp-card" href={bcp.href}>
        <div>
          <p class="eyebrow">{bcp.eyebrow}</p>
          <h3>{bcp.name}</h3>
          <p>{bcp.thesis}</p>
        </div>
        <span>{bcp.proof} <ArrowUpRight aria-hidden="true" size={18} /></span>
      </a>
    </div>
  </section>

  <section id="experience" class="experience-home section-pad" aria-labelledby="experience-title">
    <div class="section-shell experience-layout">
      <div class="experience-portrait">
        <img
          src="/assets/kevin-portrait.webp"
          width="1280"
          height="1202"
          alt="Portrait of Kevin Astuhuaman"
        />
        <p>Bay Area | Berkeley Haas MBA, 2026</p>
      </div>
      <div>
        <p class="eyebrow">Experience</p>
        <h2 id="experience-title">I work from customer tension to operating system.</h2>
        <div class="experience-spine">
          {experience.map((item) => (
            <article>
              <div>
                <h3>{item.organization}</h3>
                <span>{item.dates}</span>
              </div>
              <strong>{item.role}</strong>
              <p>{item.summary}</p>
            </article>
          ))}
        </div>
        <div class="button-row">
          <a class="button button-dark" href="/resume/">View full resume <ArrowUpRight aria-hidden="true" size={17} /></a>
          <a class="button" href={links.linkedin}>LinkedIn <ArrowUpRight aria-hidden="true" size={17} /></a>
        </div>
      </div>
    </div>
  </section>

  <section class="ask-invite" aria-labelledby="ask-title">
    <div class="section-shell">
      <div>
        <p class="eyebrow">Public-corpus beta</p>
        <h2 id="ask-title">Have a specific recruiting question?</h2>
      </div>
      <div>
        <p>Ask about Kevin's product decisions, experience, or technical range. Answers are limited to the same cited public evidence used by this portfolio.</p>
        <a class="text-link" href="/ask/">Ask Kevin's portfolio <ArrowUpRight aria-hidden="true" size={18} /></a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .home-hero {
    position: relative;
    display: flex;
    min-height: 92svh;
    padding: 132px clamp(20px, 5vw, 76px) 88px;
    align-items: center;
    overflow: clip;
    background: #090d15;
    color: white;
  }

  .hero-scene {
    position: absolute;
    z-index: 0;
    top: 96px;
    right: clamp(-240px, -8vw, -80px);
    bottom: 72px;
    width: min(64vw, 920px);
    opacity: 0.72;
  }

  .hero-console {
    height: 100%;
    min-height: 540px;
    padding: 26px;
    border: 1px solid #475165;
    border-radius: 6px;
    background: #141b28;
    box-shadow: 0 30px 90px rgba(0, 0, 0, 0.42);
  }

  .scene-toolbar {
    display: flex;
    min-height: 48px;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    border-bottom: 1px solid #465064;
    color: #e8edf5;
    font-size: 0.78rem;
    font-weight: 800;
  }

  .scene-toolbar b {
    padding: 5px 8px;
    border: 1px solid #59677c;
    border-radius: 4px;
    color: #8be0cf;
    font-size: 0.68rem;
  }

  .scene-question {
    max-width: 620px;
    margin: 48px 0 36px;
    color: white;
    font-size: clamp(1.4rem, 3vw, 2.5rem);
    font-weight: 750;
    line-height: 1.12;
  }

  .scene-progress {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
  }

  .scene-progress i {
    height: 5px;
    background: #445064;
  }

  .scene-progress i:nth-child(-n + 3) {
    background: #3f8be0;
  }

  .scene-columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    margin-top: 40px;
    gap: 14px;
  }

  .scene-columns > div {
    min-height: 270px;
    padding: 20px;
    border: 1px solid #394459;
    background: #0d131e;
  }

  .scene-columns span,
  .scene-columns strong,
  .scene-columns p,
  .scene-columns em {
    display: block;
  }

  .scene-columns span {
    margin-bottom: 18px;
    color: #c4cedc;
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .scene-columns strong {
    padding: 13px 0;
    border-bottom: 1px solid #313b4d;
    color: #d8e0eb;
    font-size: 0.78rem;
  }

  .scene-columns p {
    margin: 18px 0 5px;
    color: #69d2e7;
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .scene-columns em {
    max-width: 250px;
    color: #d6dde8;
    font-size: 0.78rem;
    font-style: normal;
    line-height: 1.4;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    width: min(760px, 100%);
    padding: 30px 36px 30px 0;
    background: rgba(9, 13, 21, 0.88);
  }

  .hero-content h1 {
    margin-bottom: 22px;
    font-size: clamp(4.8rem, 9vw, 8.2rem);
  }

  .hero-thesis {
    max-width: 720px;
    margin-bottom: 28px;
    color: #f2f2ec;
    font-size: 1.5rem;
    line-height: 1.45;
  }

  .hero-support {
    max-width: 660px;
    margin: -10px 0 28px;
    color: #bfc8d6;
    font-size: 0.96rem;
  }

  .hero-next,
  .hero-proof {
    position: absolute;
    z-index: 2;
    right: clamp(20px, 5vw, 76px);
    bottom: 32px;
    font-size: 0.78rem;
  }

  .hero-next {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    gap: 7px;
    font-weight: 700;
  }

  .hero-proof {
    top: 96px;
    bottom: auto;
    padding: 7px 10px;
    background: #121722;
    border: 1px solid #475165;
  }

  .proof-band {
    background: #0b0b0b;
    color: white;
  }

  .proof-band-inner {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
  }

  .proof-band-inner > div {
    min-height: 128px;
    padding: 28px 30px 28px 0;
  }

  .proof-band-inner > div + div {
    padding-left: 30px;
    border-left: 1px solid #3b3b3b;
  }

  .proof-band strong,
  .proof-band span {
    display: block;
  }

  .proof-band strong {
    margin-bottom: 8px;
    font-size: 1.15rem;
  }

  .proof-band span {
    color: #c9c9c4;
    font-size: 0.9rem;
  }

  .paypal-story {
    background: #ffffff;
  }

  .paypal-metrics {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    margin-top: 58px;
    border-top: 1px solid #cfd5dd;
    border-bottom: 1px solid #cfd5dd;
  }

  .paypal-metrics > div {
    min-height: 132px;
    padding: 24px 28px 24px 0;
  }

  .paypal-metrics > div + div {
    padding-left: 28px;
    border-left: 1px solid #cfd5dd;
  }

  .paypal-metrics strong,
  .paypal-metrics span {
    display: block;
  }

  .paypal-metrics strong {
    color: #0057b8;
    font-size: 2.45rem;
    line-height: 1;
  }

  .paypal-metrics span {
    max-width: 260px;
    margin-top: 12px;
    color: #575d66;
    font-size: 0.86rem;
  }

  .workbench-stage {
    margin-top: 64px;
  }

  .paypal-decisions {
    border-color: #cfd5dd;
  }

  .trackly-story {
    background: #f7f7f2;
  }

  .story-heading {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(300px, 0.8fr);
    gap: 72px;
    align-items: end;
  }

  .story-heading h2 {
    max-width: 760px;
    margin-bottom: 0;
  }

  .product-stage {
    margin-top: 72px;
    background: #15121d;
    border-radius: 6px;
    overflow: hidden;
  }

  .product-stage img {
    width: 100%;
    height: auto;
  }

  .product-stage-caption {
    display: flex;
    padding: 16px 18px;
    justify-content: space-between;
    gap: 24px;
    background: #0b0b0b;
    color: #deded8;
    font-size: 0.82rem;
  }

  .product-stage-caption span:last-child {
    max-width: 720px;
    text-align: right;
  }

  .decisions-home {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    margin-top: 56px;
    border-top: 1px solid #cfcfc8;
  }

  .decisions-home article {
    padding: 28px 32px 12px 0;
  }

  .decisions-home article + article {
    padding-left: 32px;
    border-left: 1px solid #cfcfc8;
  }

  .decisions-home article > span {
    color: #6c6c66;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.78rem;
  }

  .decisions-home h3 {
    margin: 30px 0 12px;
  }

  .decisions-home p {
    color: #4d4d48;
  }

  .work-cta {
    display: flex;
    margin-top: 48px;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .work-cta > span {
    color: #65655f;
    font-size: 0.85rem;
  }

  .selected-work {
    background: #e9e9e3;
  }

  .section-intro {
    margin-bottom: 48px;
  }

  .section-intro h2 {
    max-width: 890px;
  }

  .work-pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }

  .work-card {
    display: flex;
    min-height: 430px;
    padding: clamp(28px, 4vw, 48px);
    flex-direction: column;
    justify-content: space-between;
    border-radius: 6px;
    color: white;
    text-decoration: none;
  }

  .work-card h3 {
    max-width: 540px;
    margin: 26px 0 18px;
    font-size: 3.25rem;
  }

  .work-card p:not(.eyebrow) {
    max-width: 540px;
    color: rgba(255, 255, 255, 0.92);
    font-size: 1.05rem;
  }

  .work-card > span {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.86rem;
    font-weight: 700;
  }

  .mobagel-card {
    background: #5b2b62;
  }

  .bcp-card {
    background: #087858;
  }

  .experience-home {
    background: white;
  }

  .ask-invite {
    padding-block: 54px;
    background: #d8ff52;
  }

  .ask-invite .section-shell {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: end;
  }

  .ask-invite h2,
  .ask-invite p {
    margin-bottom: 0;
  }

  .ask-invite h2 {
    font-size: 2.6rem;
  }

  .ask-invite p {
    max-width: 590px;
  }

  .ask-invite .text-link {
    margin-top: 18px;
  }

  .experience-layout {
    display: grid;
    grid-template-columns: minmax(280px, 0.72fr) minmax(0, 1.28fr);
    gap: clamp(48px, 8vw, 112px);
  }

  .experience-portrait img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    object-position: center;
    border-radius: 6px;
  }

  .experience-portrait p {
    margin-top: 12px;
    color: #666660;
    font-size: 0.82rem;
  }

  .experience-layout h2 {
    max-width: 780px;
  }

  .experience-spine {
    margin: 48px 0 36px;
    border-top: 1px solid #d7d7d0;
  }

  .experience-spine article {
    padding: 28px 0;
    border-bottom: 1px solid #d7d7d0;
  }

  .experience-spine article > div {
    display: flex;
    justify-content: space-between;
    gap: 20px;
  }

  .experience-spine h3 {
    margin-bottom: 8px;
  }

  .experience-spine span {
    color: #666660;
    font-size: 0.88rem;
  }

  .experience-spine strong {
    display: block;
    margin-bottom: 8px;
    font-size: 0.92rem;
  }

  .experience-spine p {
    color: #555550;
  }

  @media (max-width: 800px) {
    .home-hero {
      min-height: calc(100svh - 52px);
      padding: 104px 20px 78px;
      align-items: center;
    }

    .hero-scene {
      top: 66px;
      right: -220px;
      bottom: 42px;
      width: 760px;
      opacity: 0.72;
    }

    .hero-console {
      min-height: 0;
    }

    .hero-content h1 {
      font-size: 3.55rem;
    }

    .hero-content {
      padding-right: 0;
      background: rgba(9, 13, 21, 0.94);
    }

    .hero-thesis {
      font-size: 1.04rem;
    }

    .hero-next {
      right: auto;
      left: 20px;
      bottom: 18px;
    }

    .hero-proof {
      top: 78px;
      right: 20px;
    }

    .proof-band-inner,
    .paypal-metrics,
    .decisions-home,
    .work-pair,
    .experience-layout,
    .story-heading,
    .ask-invite .section-shell {
      grid-template-columns: 1fr;
    }

    .proof-band-inner > div,
    .proof-band-inner > div + div,
    .paypal-metrics > div,
    .paypal-metrics > div + div,
    .decisions-home article,
    .decisions-home article + article {
      padding: 22px 0;
      border-left: 0;
    }

    .proof-band-inner > div + div,
    .paypal-metrics > div + div,
    .decisions-home article + article {
      border-top: 1px solid #3b3b3b;
    }

    .paypal-metrics > div + div {
      border-color: #cfd5dd;
    }

    .decisions-home article + article {
      border-color: #cfcfc8;
    }

    .story-heading {
      gap: 24px;
    }

    .product-stage-caption,
    .work-cta,
    .experience-spine article > div {
      align-items: flex-start;
      flex-direction: column;
    }

    .product-stage-caption span:last-child {
      text-align: left;
    }

    .work-card {
      min-height: 340px;
    }

    .work-card h3 {
      font-size: 2.15rem;
    }

    .experience-portrait {
      max-width: 420px;
    }

    .ask-invite h2 {
      font-size: 2rem;
    }
  }

  @media (max-width: 600px) {
    .hero-scene {
      display: none;
    }

    .hero-proof {
      right: auto;
      left: 20px;
    }
  }

  @media (max-width: 390px) {
    .hero-content h1 {
      font-size: 3.25rem;
    }

    .hero-content .button {
