---
import { ArrowUpRight, Download, Mail } from "@lucide/astro";
import InvestigationWorkbench from "../components/InvestigationWorkbench.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { experience, links, projects, publicClaims, site } from "../data/site.js";

const paypal = projects.find((project) => project.id === "paypal") ?? projects[0];
const trackly = projects.find((project) => project.id === "trackly") ?? projects[1];
const mobagel = projects.find((project) => project.id === "mobagel") ?? projects[2];
const bcp = projects.find((project) => project.id === "bcp") ?? projects[3];
const paypalClaim = publicClaims.find((claim) => claim.id === "paypal-detection") ?? publicClaims[0];
---

<BaseLayout
  title="Kevin Astuhuaman | AI Product Manager"
  description={site.description}
  path="/"
  pageType="profile"
>
  <div class="portfolio-frame">
    <section class="recruiter-hero" aria-labelledby="home-title">
      <aside class="identity-panel">
        <div>
          <img
            class="identity-portrait"
            src="/assets/kevin-portrait.webp"
            width="1280"
            height="1202"
            alt="Kevin Astuhuaman"
          />
          <h1 id="home-title">Kevin<br />Astuhuaman</h1>
          <div class="identity-stack">
            <span>AI Product Manager</span>
            <span>Berkeley Haas MBA, 2026</span>
            <span>Bay Area</span>
          </div>
        </div>
        <div class="role-focus">
          <strong>Applied AI, agent products, and technical platforms.</strong>
          <span>Product judgment, design craft, and hands-on technical execution across enterprise, startup, and regulated environments.</span>
        </div>
      </aside>

      <div class="hero-main">
        <div class="mode-switch" aria-label="Portfolio emphasis">
          <button type="button" data-home-mode="recruiter" aria-controls="home-panel-recruiter" aria-pressed="true">Recruiter</button>
          <button type="button" data-home-mode="builder" aria-controls="home-panel-builder" aria-pressed="false">Builder</button>
          <button type="button" data-home-mode="agent" aria-controls="home-panel-agent" aria-pressed="false">Agent</button>
        </div>

        <div class="hero-copy">
          <div id="home-panel-recruiter" data-home-panel="recruiter">
            <p class="eyebrow">AI Product Manager | Berkeley Haas MBA '26</p>
            <h2>Seven years building products and enjoying every minute of it.</h2>
            <p class="hero-lede">Most recently, I built agentic observability prototypes for PayPal Checkout. At Berkeley Haas, I worked on AI product adoption, a high-fidelity Figma prototype, roadmap, business model, and go-to-market recommendations.</p>
            <p class="hero-detail">I also built Trackly across web, iOS, macOS, CLI, MCP, chat, and voice, and progressed through four product roles at Banco de Credito BCP.</p>
          </div>
          <div id="home-panel-builder" data-home-panel="builder" hidden>
            <p class="eyebrow">Hands-on product building</p>
            <h2>I stay close to the customer, interface, and system.</h2>
            <p class="hero-lede">Trackly began with one job-search timing problem and became a live product across web, native apps, a public CLI, MCP, chat, voice, matching, and the monitoring infrastructure behind them.</p>
            <p class="hero-detail">The point is not the number of surfaces. It is owning the product promise, quality thresholds, failure states, releases, and operating decisions end to end.</p>
          </div>
          <div id="home-panel-agent" data-home-panel="agent" hidden>
            <p class="eyebrow">For recruiters and AI systems</p>
            <h2>Public evidence should be easy to inspect and hard to misread.</h2>
            <p class="hero-lede">This portfolio publishes the same verified profile as accessible HTML, Markdown, JSON, cited case studies, and a deterministic recruiter assistant.</p>
            <p class="hero-detail">Production outcomes, prototypes, public-safe reconstructions, and open-source work are labeled separately so an AI tool does not have to infer the boundary.</p>
          </div>

          <div class="button-row">
            <a class="button button-primary" href="/projects/paypal-ai-observability/">
              See PayPal work <ArrowUpRight aria-hidden="true" size={17} />
            </a>
            <a class="button" href="/resume/">
              <Download aria-hidden="true" size={17} /> Resume
            </a>
            <a class="button" href="/contact/">
              <Mail aria-hidden="true" size={17} /> Contact
            </a>
          </div>
        </div>

        <div class="proof-strip" aria-label="Selected evidence">
          <div><strong>PayPal</strong><span>{paypalClaim.short}</span></div>
          <div><strong>Berkeley Haas</strong><span>AI product strategy and high-fidelity Figma prototyping</span></div>
          <div><strong>Trackly</strong><span>Live across App Store, web, CLI, MCP, chat, and voice</span></div>
          <div><strong>BCP / Credicorp</strong><span>Lead Product Manager with nine direct reports</span></div>
        </div>
      </div>
    </section>

    <div class="black-band">
      <strong>AI product manager, builder, and fintech operator</strong>
      <nav aria-label="Quick links">
        <a href="#work">Selected work</a>
        <a href="#human-control-plane">Control patterns</a>
        <a href="#workbench">Interactive prototype</a>
        <a href="#experience">Experience</a>
        <a href="/proof/">Evidence</a>
      </nav>
    </div>

    <section id="work" class="section-grid" aria-labelledby="selected-title">
      <div class="section-label">
        <p class="eyebrow">Selected work</p>
        <h2 id="selected-title">Four environments. One product standard.</h2>
        <p>Start with the customer decision, make system behavior understandable, and define what evidence is strong enough to ship.</p>
      </div>
      <div class="work-grid">
        <a class="work-card" href={paypal.href}>
          <div class="card-meta"><span class="chip blue">Recent enterprise AI</span><span>Prototype + POC</span></div>
          <div><h3>{paypal.name}</h3><p>{paypal.thesis}</p></div>
          <img src="/assets/workbench-review.png" width="1280" height="640" alt="AI Investigation Workbench at the human-review state" />
        </a>

        <a class="work-card" href={mobagel.href}>
          <div class="card-meta"><span class="chip lime">Berkeley Haas</span><span>AI strategy + design</span></div>
          <div><h3>{mobagel.name}</h3><p>{mobagel.thesis}</p></div>
          <div class="berkeley-visual" aria-hidden="true">
            <strong>Fujitsu / MoBagel</strong>
            <span>Research</span><span>Figma</span><span>Roadmap</span><span>GTM</span>
          </div>
        </a>

        <a class="work-card" href={trackly.href}>
          <div class="card-meta"><span class="chip lime">Live product</span><span>Multi-surface system</span></div>
          <div><h3>{trackly.name}</h3><p>{trackly.thesis}</p></div>
          <img src={trackly.image} width="1440" height="1000" loading="lazy" alt="Trackly homepage showing direct career-page monitoring" />
        </a>

        <a class="work-card" href={bcp.href}>
          <div class="card-meta"><span class="chip green">Regulated scale</span><span>Production outcomes</span></div>
          <div><h3>{bcp.name}</h3><p>{bcp.thesis}</p></div>
          <div class="bcp-visual" aria-label="BCP product areas">
            <span>Lending</span><span>Risk</span><span>Growth</span>
            <span>Digital channels</span><span>APIs</span><span>Leadership</span>
          </div>
        </a>
      </div>
    </section>

    <section id="builder-stack" class="builder-map-band" aria-labelledby="builder-map-title">
      <div class="builder-map-copy">
        <p class="eyebrow">Technical range, made inspectable</p>
        <h2 id="builder-map-title">65 entries, organized by what I built with them.</h2>
        <p>I mapped the models, infrastructure, observability, browser automation, voice, design, and delivery tools I have actually used. Every entry names the product outcome and evidence behind it, then labels the work as shipped, active, prototype, or historical.</p>
        <div class="button-row">
          <a class="button button-primary" href={links.builderStack}>Explore the builder stack <ArrowUpRight aria-hidden="true" size={17} /></a>
          <a class="button" href={links.builderStackRepo}>View source <ArrowUpRight aria-hidden="true" size={17} /></a>
        </div>
      </div>
      <a class="builder-map-preview" href={links.builderStack} aria-label="Open the interactive AI Product Builder Stack">
        <img src="/assets/builder-stack-preview.png" width="1280" height="640" loading="lazy" alt="AI Product Builder Stack showing 65 verified tools and product patterns" />
        <span><strong>Four end-to-end flows</strong> Trackly discovery, browser agent, voice onboarding, and conversation follow-up</span>
      </a>
    </section>

    <section id="human-control-plane" class="control-plane-band" aria-labelledby="control-plane-title">
      <a class="control-plane-preview" href={links.humanControlPlane} aria-label="Open the interactive Human Control Plane">
        <img src="/assets/human-control-plane-preview.png" width="1200" height="630" loading="lazy" alt="Human Control Plane showing operating conditions, a recommended approval policy, and an audit record" />
        <span><strong>Live product study</strong> Four scenarios · deterministic policy · public source</span>
      </a>
      <div class="control-plane-copy">
        <p class="eyebrow">Human oversight, made operational</p>
        <h2 id="control-plane-title">Capability is not permission.</h2>
        <p>The right control depends on the action. This interactive lab turns consequence, reversibility, uncertainty, and intent into a visible product policy, then proves what happens when approval expires or a user needs Undo.</p>
        <div class="control-pattern-list" aria-label="Human control patterns">
          <span>Execute + Undo</span><span>Preview + Confirm</span><span>Fresh approval</span><span>Accountable owner</span>
        </div>
        <div class="button-row">
          <a class="button button-primary" href={links.humanControlPlane}>Try the control plane <ArrowUpRight aria-hidden="true" size={17} /></a>
          <a class="button" href={links.humanControlPlaneRepo}>Inspect the decisions <ArrowUpRight aria-hidden="true" size={17} /></a>
        </div>
      </div>
    </section>

    <section id="workbench" class="prototype-section" aria-labelledby="prototype-title">
      <div class="prototype-intro">
        <div>
          <p class="eyebrow">Interactive product proof</p>
          <h2 id="prototype-title">Make the agent's work inspectable before it becomes actionable.</h2>
        </div>
        <p>The public-safe reconstruction uses fictional commerce data. It shows the product decisions behind bounded planning, evidence provenance, visible uncertainty, and accountable human routing without exposing PayPal systems or assets.</p>
      </div>

      <div class="metric-strip" aria-label="PayPal internship project scope and results">
        <div><strong>15+</strong><span>diagnostic tools in the project landscape</span></div>
        <div><strong>75%</strong><span>faster issue detection in the internship prototype workflow</span></div>
        <div><strong>5x</strong><span>faster triage in the auto-triage proof of concept</span></div>
      </div>

      <div class="workbench-wrap">
        <InvestigationWorkbench headingLevel="h3" />
      </div>

      <div class="decision-strip">
        <article><span>01</span><h3>Bound the plan</h3><p>Show sources, permissions, and intended steps before execution.</p></article>
        <article><span>02</span><h3>Preserve uncertainty</h3><p>Separate observations, inferences, contradictions, and unknowns.</p></article>
        <article><span>03</span><h3>Keep ownership human</h3><p>The agent drafts the handoff. A person decides whether it is ready.</p></article>
      </div>
    </section>

    <section id="experience" class="section-grid experience-section" aria-labelledby="experience-title">
      <div class="section-label">
        <p class="eyebrow">Experience</p>
        <h2 id="experience-title">Customer tension to operating system.</h2>
        <p>Recent AI product work, zero-to-one building, startup strategy, and six years of regulated product leadership.</p>
        <a class="text-link" href="/resume/">View full resume <ArrowUpRight aria-hidden="true" size={17} /></a>
      </div>
      <div class="timeline-grid">
        {experience.map((item, index) => (
          <article>
            <span>0{index + 1}</span>
            <time>{item.dates}</time>
            <h3>{item.organization}</h3>
            <strong>{item.role}</strong>
            <p>{item.summary}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="ask-band" aria-labelledby="ask-title">
      <div><p class="eyebrow">Public-corpus beta</p><h2 id="ask-title">Have a specific recruiting question?</h2></div>
      <div><p>Ask about product decisions, experience, or technical range. Answers stay inside the same cited public evidence.</p><a class="text-link" href="/ask/">Ask Kevin's portfolio <ArrowUpRight aria-hidden="true" size={17} /></a></div>
    </section>
  </div>

  <script>
    document.querySelectorAll("[data-home-mode]").forEach((button) => {
      button.addEventListener("click", () => {
        const mode = button.getAttribute("data-home-mode");
        document.querySelectorAll("[data-home-mode]").forEach((candidate) => {
          candidate.setAttribute("aria-pressed", String(candidate === button));
        });
        document.querySelectorAll("[data-home-panel]").forEach((panel) => {
          if (panel.getAttribute("data-home-panel") === mode) panel.removeAttribute("hidden");
          else panel.setAttribute("hidden", "");
        });
      });
    });
  </script>
</BaseLayout>

<style>
  .portfolio-frame {
    max-width: 1440px;
    margin-inline: auto;
    background: #f6f7f8;
  }

  .recruiter-hero {
    display: grid;
    grid-template-columns: minmax(310px, 0.72fr) minmax(0, 1.28fr);
    min-height: 720px;
    border-bottom: 1px solid #171717;
  }

  .identity-panel {
    display: flex;
    padding: 40px;
    flex-direction: column;
    justify-content: space-between;
    gap: 40px;
    border-right: 1px solid #171717;
  }

  .identity-portrait {
    width: 136px;
    height: 136px;
    border: 1px solid #171717;
    border-radius: 50%;
    object-fit: cover;
  }

  .identity-panel h1 {
    margin: 30px 0 22px;
    font-size: clamp(3.8rem, 5vw, 5rem);
    line-height: 0.9;
  }

  .identity-stack {
    display: grid;
    gap: 5px;
    color: #2f3437;
    font-size: 1rem;
  }

  .role-focus {
    display: grid;
    padding: 18px;
    gap: 9px;
    border: 1px solid #171717;
    border-radius: 6px;
    background: white;
  }

  .role-focus span {
    color: #62666c;
    font-size: 0.9rem;
  }

  .hero-main {
    display: grid;
    min-width: 0;
    grid-template-rows: auto 1fr auto;
  }

  .mode-switch {
    display: flex;
    border-bottom: 1px solid #171717;
  }

  .mode-switch button {
    flex: 1;
    min-height: 54px;
    border: 0;
    border-right: 1px solid #171717;
    background: transparent;
    color: #62666c;
    font-weight: 800;
    text-transform: uppercase;
    cursor: pointer;
  }

  .mode-switch button:last-child {
    border-right: 0;
  }

  .mode-switch button[aria-pressed="true"] {
    background: #11110f;
    color: white;
  }

  .hero-copy {
    display: grid;
    padding: 48px 44px;
    align-content: center;
    gap: 28px;
  }

  .hero-copy h2 {
    max-width: 900px;
    margin-bottom: 22px;
    font-size: clamp(3rem, 5vw, 5rem);
  }

  .hero-lede {
    max-width: 820px;
    margin-bottom: 16px;
    color: #2f3437;
    font-size: 1.2rem;
    line-height: 1.5;
  }

  .hero-detail {
    max-width: 760px;
    color: #62666c;
  }

  .button-primary {
    border-color: #1652f0;
    background: #1652f0;
    color: white;
  }

  .proof-strip {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid #171717;
  }

  .proof-strip > div {
    min-height: 142px;
    padding: 20px;
    border-right: 1px solid #171717;
  }

  .proof-strip > div:last-child {
    border-right: 0;
  }

  .proof-strip strong,
  .proof-strip span {
    display: block;
  }

  .proof-strip strong {
    margin-bottom: 12px;
    font-size: 1.2rem;
  }

  .proof-strip span {
    color: #62666c;
    font-size: 0.84rem;
  }

  .black-band {
    display: flex;
    min-height: 64px;
    padding: 16px 40px;
    align-items: center;
    justify-content: space-between;
    gap: 22px;
    border-bottom: 1px solid #171717;
    background: #11110f;
    color: white;
  }

  .black-band nav {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    font-size: 0.84rem;
  }

  .section-grid {
    display: grid;
    grid-template-columns: minmax(250px, 0.5fr) minmax(0, 1.5fr);
    border-bottom: 1px solid #171717;
    background: white;
  }

  .section-label {
    padding: 34px 28px;
    border-right: 1px solid #171717;
  }

  .section-label h2 {
    margin-bottom: 18px;
    font-size: 2.2rem;
  }

  .section-label p:not(.eyebrow) {
    color: #62666c;
  }

  .work-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .work-card {
    display: grid;
    min-width: 0;
    min-height: 440px;
    padding: 24px;
    align-content: space-between;
    gap: 22px;
    border-right: 1px solid #171717;
    border-bottom: 1px solid #171717;
    background: #f6f7f8;
    text-decoration: none;
  }

  .work-card:nth-child(2n) {
    border-right: 0;
  }

  .work-card:nth-last-child(-n + 2) {
    border-bottom: 0;
  }

  .work-card h3 {
    margin-bottom: 10px;
    font-size: 2rem;
  }

  .work-card p {
    margin-bottom: 0;
    color: #40444a;
  }

  .work-card img,
  .berkeley-visual,
  .bcp-visual {
    width: 100%;
    min-height: 190px;
    border: 1px solid #171717;
    border-radius: 6px;
  }

  .work-card img {
    height: 190px;
    object-fit: cover;
    object-position: top;
  }

  .card-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    color: #62666c;
    font-size: 0.76rem;
  }

  .chip {
    display: inline-flex;
    min-height: 26px;
    padding: 3px 8px;
    align-items: center;
    border: 1px solid #171717;
    border-radius: 4px;
    background: white;
    color: #11110f;
    font-weight: 800;
  }

  .chip.blue { border-color: #1652f0; background: #eaf0ff; }
  .chip.lime { background: #d8ff52; }
  .chip.green { border-color: #087858; background: #e4f5ef; }

  .berkeley-visual {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    padding: 20px;
    gap: 8px;
    background: #d8ff52;
  }

  .berkeley-visual strong {
    grid-column: 1 / -1;
    align-self: end;
    margin-bottom: 14px;
    font-size: 1.55rem;
  }

  .berkeley-visual span,
  .bcp-visual span {
    display: grid;
    place-items: center;
    min-height: 42px;
    border: 1px solid #171717;
    background: white;
    font-size: 0.8rem;
    font-weight: 800;
  }

  .bcp-visual {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    padding: 14px;
    gap: 9px;
    background: #e4f5ef;
  }

  .builder-map-band {
    display: grid;
    grid-template-columns: minmax(300px, 0.78fr) minmax(0, 1.22fr);
    border-bottom: 1px solid #171717;
    background: #e4f5ef;
  }

  .builder-map-copy {
    display: grid;
    padding: 44px 36px;
    align-content: center;
    border-right: 1px solid #171717;
  }

  .builder-map-copy h2 {
    max-width: 520px;
    margin-bottom: 20px;
    font-size: clamp(2.25rem, 4vw, 3.7rem);
  }

  .builder-map-copy > p:not(.eyebrow) {
    max-width: 590px;
    color: #40444a;
  }

  .builder-map-preview {
    display: grid;
    min-width: 0;
    grid-template-columns: minmax(0, 1fr);
    padding: 32px;
    align-content: center;
    gap: 14px;
    color: #40444a;
    text-decoration: none;
  }

  .builder-map-preview img {
    width: 100%;
    height: auto;
    min-width: 0;
    border: 1px solid #171717;
    border-radius: 6px;
  }

  .builder-map-preview span {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    font-size: 0.8rem;
  }

  .control-plane-band {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
    border-bottom: 1px solid #171717;
    background: #fff7ef;
  }

  .control-plane-preview {
    display: grid;
    min-width: 0;
    padding: 32px;
    align-content: center;
    gap: 14px;
    border-right: 1px solid #171717;
    color: #40444a;
    text-decoration: none;
  }

  .control-plane-preview img {
    width: 100%;
    height: auto;
    min-width: 0;
    border: 1px solid #171717;
    border-radius: 6px;
  }

  .control-plane-preview > span {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    font-size: 0.8rem;
  }

  .control-plane-copy {
    display: grid;
    padding: 44px 36px;
    align-content: center;
  }

  .control-plane-copy h2 {
    max-width: 520px;
    margin-bottom: 20px;
    font-size: clamp(2.25rem, 4vw, 3.7rem);
  }

  .control-plane-copy > p:not(.eyebrow) {
    max-width: 590px;
    color: #40444a;
  }

  .control-pattern-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    margin: 22px 0 26px;
    border-top: 1px solid #d7cfc5;
  }

  .control-pattern-list span {
    padding: 10px 0;
    border-bottom: 1px solid #d7cfc5;
    font-size: 0.78rem;
    font-weight: 800;
  }

  .control-pattern-list span:nth-child(even) {
    padding-left: 16px;
    border-left: 1px solid #d7cfc5;
  }

  .builder-map-preview strong {
    color: #11110f;
  }

  .prototype-section {
    padding: 72px 40px;
    border-bottom: 1px solid #171717;
    background: #f6f7f8;
  }

  .prototype-intro {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 64px;
    align-items: end;
  }

  .prototype-intro h2 {
    max-width: 780px;
    margin-bottom: 0;
    font-size: clamp(2.8rem, 5vw, 4.8rem);
  }

  .prototype-intro > p {
    color: #4b4f55;
    font-size: 1.05rem;
  }

  .metric-strip,
  .decision-strip {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    margin-top: 46px;
    border-top: 1px solid #171717;
    border-bottom: 1px solid #171717;
  }

  .metric-strip > div,
  .decision-strip article {
    padding: 22px;
    border-right: 1px solid #171717;
  }

  .metric-strip > div:last-child,
  .decision-strip article:last-child {
    border-right: 0;
  }

  .metric-strip strong,
  .metric-strip span {
    display: block;
  }

  .metric-strip strong {
    color: #1652f0;
    font-size: 2.5rem;
  }

  .metric-strip span {
    margin-top: 8px;
    color: #62666c;
    font-size: 0.84rem;
  }

  .workbench-wrap {
    margin-top: 48px;
