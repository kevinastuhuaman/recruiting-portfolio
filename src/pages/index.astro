---
import { ArrowUpRight, FileText, MessageCircle, Mic } from "@lucide/astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import HomepagePortfolioOrb from "../components/portfolio/HomepagePortfolioOrb";
import { experience, projects, site } from "../data/site.js";
import { claimsById } from "../data/claims.js";

const paypal = projects.find((project) => project.id === "paypal") ?? projects[0];
const trackly = projects.find((project) => project.id === "trackly") ?? projects[1];
const mobagel = projects.find((project) => project.id === "mobagel") ?? projects[2];
const paypalClaim = claimsById["paypal-detection"];
---

<BaseLayout title="Kevin Astuhuaman | AI Product Manager" description={site.description} path="/" pageType="profile">
  <div class="portfolio-frame">
    <section class="recruiter-hero recruiter-hero-v2" aria-labelledby="home-title">
      <div class="hero-portrait-column">
        <img class="identity-portrait" src="/assets/kevin-portrait.webp" width="1280" height="1202" alt="Kevin Astuhuaman" />
        <div class="hero-availability"><span></span> Bay Area</div>
      </div>
      <div class="hero-copy hero-copy-v2">
        <p class="eyebrow">AI Product Manager</p>
        <h1 id="home-title">Kevin Astuhuaman</h1>
        <h2>Seven years building products and enjoying every minute of it.</h2>
        <p class="hero-lede">Ex-PayPal AI/ML observability. Berkeley Haas MBA. I turn complex AI systems into products people can understand, trust, and use.</p>
        <div class="identity-stack identity-stack-v2">
          <span>Applied AI and agents</span><span>Enterprise platforms</span><span>Zero-to-one execution</span>
        </div>
        <div class="button-row">
          <a class="button button-primary" href="#work">View selected work <ArrowUpRight aria-hidden="true" size={17} /></a>
          <a class="button" href="/ask/">Ask the portfolio <MessageCircle aria-hidden="true" size={17} /></a>
          <a class="button" href="/resume/"><FileText aria-hidden="true" size={17} /> View resume</a>
        </div>
      </div>
    </section>

    <section id="credibility" class="proof-strip proof-strip-v2" aria-label="Credibility">
      <div><strong>PayPal Checkout</strong><span>AI observability prototype</span></div>
      <div><strong>Berkeley Haas</strong><span>STEM MBA, 2026</span></div>
      <div><strong>Trackly</strong><span>Web, native, CLI, MCP, chat, voice</span></div>
      <div><strong>BCP / Credicorp</strong><span>Six years of product progression</span></div>
    </section>

    <section id="work" class="selected-work-v2" aria-labelledby="work-title">
      <header class="editorial-heading">
        <p class="eyebrow">Selected work</p>
        <h2 id="work-title">The evidence behind the title.</h2>
        <p>Enterprise AI, hands-on building, and regulated product leadership. Each case names what shipped, what stayed a prototype, and how the decision was evaluated.</p>
      </header>

      <article id="paypal" class="feature-story feature-story-paypal" data-project-card>
        <div class="feature-index">01</div>
        <div class="feature-copy">
          <p class="eyebrow">PayPal Checkout | Prototype + POC</p>
          <h3>Make fragmented diagnostics feel like one investigation.</h3>
          <p>{paypal.thesis}</p>
          <div class="metric-inline"><strong>{paypalClaim.metrics?.[0]?.value}</strong><span>{paypalClaim.metrics?.[0]?.label}</span><strong>{claimsById["paypal-discovery"].metrics?.[1]?.value}</strong><span>{claimsById["paypal-discovery"].metrics?.[1]?.label}</span></div>
          <a class="text-link" href={paypal.href}>Read the PayPal case <ArrowUpRight aria-hidden="true" size={17} /></a>
        </div>
        <figure class="feature-media" data-project-media>
          <img src="/assets/workbench-review.png" width="1280" height="640" alt="Public-safe AI investigation workflow at the human review state" />
          <figcaption>Public-safe reconstruction with fictional commerce data. No PayPal systems or assets.</figcaption>
        </figure>
      </article>

      <article id="trackly" class="feature-story feature-story-trackly" data-project-card>
        <div class="feature-index">02</div>
        <div class="feature-copy">
          <p class="eyebrow">Trackly | Live product</p>
          <h3>Own the promise, including the failure states.</h3>
          <p>{trackly.thesis}</p>
          <a class="text-link" href={trackly.href}>Explore Trackly <ArrowUpRight aria-hidden="true" size={17} /></a>
        </div>
        <div class="trackly-proof">
          <img src={trackly.image} width="1440" height="1000" loading="lazy" alt="Trackly homepage showing direct career-page monitoring" />
          <ol class="state-flow" aria-label="Trackly product decision sequence">
            <li><span>Problem</span><strong>Strong roles appeared before aggregators.</strong></li>
            <li><span>Decision</span><strong>Monitor the source: company career pages.</strong></li>
            <li><span>Failure</span><strong>A zero-result poll could look healthy.</strong></li>
            <li><span>Recovery</span><strong>False-zero guards preserve the last known signal.</strong></li>
          </ol>
        </div>
      </article>

      <article id="mobagel" class="feature-story feature-story-mobagel" data-project-card>
        <div class="feature-index">03</div>
        <div class="feature-copy">
          <p class="eyebrow">Berkeley Haas × MoBagel</p>
          <h3>Translate AI capability into an adoption path.</h3>
          <p>{mobagel.thesis}</p>
          <a class="text-link" href={mobagel.href}>View the Berkeley case <ArrowUpRight aria-hidden="true" size={17} /></a>
        </div>
        <ol class="mobagel-map" aria-label="Berkeley and MoBagel deliverables"><li data-berkeley-step><span>01</span>Discovery</li><li data-berkeley-step><span>02</span>Figma</li><li data-berkeley-step><span>03</span>Roadmap</li><li data-berkeley-step><span>04</span>Pricing</li><li data-berkeley-step><span>05</span>U.S. GTM</li></ol>
      </article>
    </section>

    <section id="experience" class="experience-v2" aria-labelledby="experience-title">
      <header class="editorial-heading editorial-heading-light">
        <p class="eyebrow">Experience</p>
        <h2 id="experience-title">I’ve kept choosing the harder product problem.</h2>
        <p>My seven years span enterprise AI, hands-on product building, AI strategy, lending, growth, and regulated operations.</p>
      </header>
      <div class="experience-list">
        {experience.map((item, index) => (
          <details open={index === 0}>
            <summary><span>0{index + 1}</span><div><h3>{item.organization}</h3><p>{item.role}</p></div><time>{item.dates}</time></summary>
            <div class="experience-detail"><p>{item.summary}</p><ul>{item.bullets.map((bullet) => <li>{bullet}</li>)}</ul></div>
          </details>
        ))}
      </div>
      <a class="button button-light" href="/resume/">View full resume <ArrowUpRight aria-hidden="true" size={17} /></a>
    </section>

    <section id="lab" class="lab-teaser-v2" aria-labelledby="lab-title">
      <div>
        <p class="eyebrow">AI Product Lab</p>
        <h2 id="lab-title">Seven working studies. One place to inspect the decisions.</h2>
        <p>Evals, agent workflows, human control, interface trust, technical range, and motion, all built with synthetic data and public boundaries.</p>
        <a class="button button-primary" href="/lab/">Explore the AI Product Lab <ArrowUpRight aria-hidden="true" size={17} /></a>
      </div>
      <a class="lab-teaser-media" href="/lab/" aria-label="Open the AI Product Lab">
        <img src="/assets/enterprise-ai-interface-kit-preview.png" width="1200" height="630" loading="lazy" alt="Enterprise AI Interface Kit preview" />
        <span><strong>07</strong> interactive artifacts</span>
      </a>
    </section>

    <section id="assistant" class="assistant-preview-v2" aria-labelledby="assistant-title">
      <div class="assistant-orb-live" aria-hidden="true"><HomepagePortfolioOrb client:visible /></div>
      <div>
        <p class="eyebrow">Ask the portfolio</p>
        <h2 id="assistant-title">Have a question? Ask.</h2>
        <p>Chat with my portfolio or start a voice conversation with my AI assistant.</p>
        <div class="assistant-modes"><span><MessageCircle aria-hidden="true" size={18} /> Chat</span><span><Mic aria-hidden="true" size={18} /> Voice</span></div>
        <a class="button button-primary" href="/ask/">Ask anything about Kevin <ArrowUpRight aria-hidden="true" size={17} /></a>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .portfolio-frame {
    max-width: 1440px;
    margin-inline: auto;
    background: #f6f7f8;
  }

  .recruiter-hero {
    display: grid;
    grid-template-columns: minmax(310px, 0.72fr) minmax(0, 1.28fr);
    min-height: 720px;
    border-bottom: 1px solid #171717;
  }

  .identity-panel {
    display: flex;
    padding: 40px;
    flex-direction: column;
    justify-content: space-between;
    gap: 40px;
    border-right: 1px solid #171717;
  }

  .identity-portrait {
    width: 136px;
    height: 136px;
    border: 1px solid #171717;
    border-radius: 50%;
    object-fit: cover;
  }

  .identity-panel h1 {
    margin: 30px 0 22px;
    font-size: clamp(3.8rem, 5vw, 5rem);
    line-height: 0.9;
  }

  .identity-stack {
    display: grid;
    gap: 5px;
    color: #2f3437;
    font-size: 1rem;
  }

  .role-focus {
    display: grid;
    padding: 18px;
    gap: 9px;
    border: 1px solid #171717;
    border-radius: 6px;
    background: white;
  }

  .role-focus span {
    color: #62666c;
    font-size: 0.9rem;
  }

  .hero-main {
    display: grid;
    min-width: 0;
    grid-template-rows: auto 1fr auto;
  }

  .mode-switch {
    display: flex;
    border-bottom: 1px solid #171717;
  }

  .mode-switch button {
    flex: 1;
    min-height: 54px;
    border: 0;
    border-right: 1px solid #171717;
    background: transparent;
    color: #62666c;
    font-weight: 800;
    text-transform: uppercase;
    cursor: pointer;
  }

  .mode-switch button:last-child {
    border-right: 0;
  }

  .mode-switch button[aria-pressed="true"] {
    background: #11110f;
    color: white;
  }

  .hero-copy {
    display: grid;
    padding: 48px 44px;
    align-content: center;
    gap: 28px;
  }

  .hero-copy h2 {
    max-width: 900px;
    margin-bottom: 22px;
    font-size: clamp(3rem, 5vw, 5rem);
  }

  .hero-lede {
    max-width: 820px;
    margin-bottom: 16px;
    color: #2f3437;
    font-size: 1.2rem;
    line-height: 1.5;
  }

  .hero-detail {
    max-width: 760px;
    color: #62666c;
  }

  .button-primary {
    border-color: #1652f0;
    background: #1652f0;
    color: white;
  }

  .proof-strip {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid #171717;
  }

  .proof-strip > div {
    min-height: 142px;
    padding: 20px;
    border-right: 1px solid #171717;
  }

  .proof-strip > div:last-child {
    border-right: 0;
  }

  .proof-strip strong,
  .proof-strip span {
    display: block;
  }

  .proof-strip strong {
    margin-bottom: 12px;
    font-size: 1.2rem;
  }

  .proof-strip span {
    color: #62666c;
    font-size: 0.84rem;
  }

  .black-band {
    display: flex;
    min-height: 64px;
    padding: 16px 40px;
    align-items: center;
    justify-content: space-between;
    gap: 22px;
    border-bottom: 1px solid #171717;
    background: #11110f;
    color: white;
  }

  .black-band nav {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    font-size: 0.84rem;
  }

  .section-grid {
    display: grid;
    grid-template-columns: minmax(250px, 0.5fr) minmax(0, 1.5fr);
    border-bottom: 1px solid #171717;
    background: white;
  }

  .section-label {
    padding: 34px 28px;
    border-right: 1px solid #171717;
  }

  .section-label h2 {
    margin-bottom: 18px;
    font-size: 2.2rem;
  }

  .section-label p:not(.eyebrow) {
    color: #62666c;
  }

  .work-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .work-card {
    display: grid;
    min-width: 0;
    min-height: 440px;
    padding: 24px;
    align-content: space-between;
    gap: 22px;
    border-right: 1px solid #171717;
    border-bottom: 1px solid #171717;
    background: #f6f7f8;
    text-decoration: none;
  }

  .work-card:nth-child(2n) {
    border-right: 0;
  }

  .work-card:nth-last-child(-n + 2) {
    border-bottom: 0;
  }

  .work-card h3 {
    margin-bottom: 10px;
    font-size: 2rem;
  }

  .work-card p {
    margin-bottom: 0;
    color: #40444a;
  }

  .work-card img,
  .berkeley-visual,
  .bcp-visual {
    width: 100%;
    min-height: 190px;
    border: 1px solid #171717;
    border-radius: 6px;
  }

  .work-card img {
    height: 190px;
    object-fit: cover;
    object-position: top;
  }

  .card-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    color: #62666c;
    font-size: 0.76rem;
  }

  .chip {
    display: inline-flex;
    min-height: 26px;
    padding: 3px 8px;
    align-items: center;
    border: 1px solid #171717;
    border-radius: 4px;
    background: white;
    color: #11110f;
    font-weight: 800;
  }

  .chip.blue { border-color: #1652f0; background: #eaf0ff; }
  .chip.lime { background: #d8ff52; }
  .chip.green { border-color: #087858; background: #e4f5ef; }

  .berkeley-visual {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    padding: 20px;
    gap: 8px;
    background: #d8ff52;
  }

  .berkeley-visual strong {
    grid-column: 1 / -1;
    align-self: end;
    margin-bottom: 14px;
    font-size: 1.55rem;
  }

  .berkeley-visual span,
  .bcp-visual span {
    display: grid;
    place-items: center;
    min-height: 42px;
    border: 1px solid #171717;
    background: white;
    font-size: 0.8rem;
    font-weight: 800;
  }

  .bcp-visual {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    padding: 14px;
    gap: 9px;
    background: #e4f5ef;
  }

  .builder-map-band {
    display: grid;
    grid-template-columns: minmax(300px, 0.78fr) minmax(0, 1.22fr);
    border-bottom: 1px solid #171717;
    background: #e4f5ef;
  }

  .builder-map-copy {
    display: grid;
    padding: 44px 36px;
    align-content: center;
    border-right: 1px solid #171717;
  }

  .builder-map-copy h2 {
    max-width: 520px;
    margin-bottom: 20px;
    font-size: clamp(2.25rem, 4vw, 3.7rem);
  }

  .builder-map-copy > p:not(.eyebrow) {
    max-width: 590px;
    color: #40444a;
  }

  .builder-map-preview {
    display: grid;
    min-width: 0;
    grid-template-columns: minmax(0, 1fr);
    padding: 32px;
    align-content: center;
    gap: 14px;
    color: #40444a;
    text-decoration: none;
  }

  .builder-map-preview img {
    width: 100%;
    height: auto;
    min-width: 0;
    border: 1px solid #171717;
    border-radius: 6px;
  }

  .builder-map-preview span {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    font-size: 0.8rem;
  }

  .interface-kit-band {
    display: grid;
    grid-template-columns: minmax(320px, 0.82fr) minmax(0, 1.18fr);
    scroll-margin-top: 72px;
    border-bottom: 1px solid #171717;
    background: #f4f4ef;
  }

  .interface-kit-copy {
    display: grid;
    padding: 44px 36px;
    align-content: center;
    border-right: 1px solid #171717;
  }

  .interface-kit-copy h2 {
    max-width: 520px;
    margin-bottom: 20px;
    font-size: clamp(2.25rem, 4vw, 3.7rem);
  }

  .interface-kit-copy > p:not(.eyebrow) {
    max-width: 590px;
    color: #40444a;
  }

  .interface-contract-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    margin: 22px 0 26px;
    border-top: 1px solid #cacac3;
  }

  .interface-contract-list span {
    padding: 10px 0;
    border-bottom: 1px solid #cacac3;
    font-size: 0.78rem;
    font-weight: 800;
  }

  .interface-contract-list span:nth-child(even) {
    padding-left: 16px;
    border-left: 1px solid #cacac3;
  }

  .interface-kit-preview {
    display: grid;
    min-width: 0;
    padding: 32px;
    align-content: center;
    gap: 14px;
    color: #40444a;
    text-decoration: none;
  }

  .interface-kit-preview img {
    width: 100%;
    height: auto;
    min-width: 0;
    border: 1px solid #171717;
    border-radius: 6px;
  }

  .interface-kit-preview > span {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    font-size: 0.8rem;
  }

  .interface-kit-preview strong { color: #11110f; }

  .control-plane-band {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
    border-bottom: 1px solid #171717;
    background: #fff7ef;
  }

  .control-plane-preview {
    display: grid;
    min-width: 0;
    padding: 32px;
    align-content: center;
    gap: 14px;
    border-right: 1px solid #171717;
    color: #40444a;
    text-decoration: none;
  }

  .control-plane-preview img {
    width: 100%;
    height: auto;
    min-width: 0;
    border: 1px solid #171717;
    border-radius: 6px;
  }

  .control-plane-preview > span {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    font-size: 0.8rem;
  }

  .control-plane-copy {
    display: grid;
    padding: 44px 36px;
    align-content: center;
  }

  .control-plane-copy h2 {
    max-width: 520px;
    margin-bottom: 20px;
    font-size: clamp(2.25rem, 4vw, 3.7rem);
  }

  .control-plane-copy > p:not(.eyebrow) {
    max-width: 590px;
    color: #40444a;
  }

  .control-pattern-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    margin: 22px 0 26px;
    border-top: 1px solid #d7cfc5;
  }

  .control-pattern-list span {
    padding: 10px 0;
    border-bottom: 1px solid #d7cfc5;
    font-size: 0.78rem;
    font-weight: 800;
  }

  .control-pattern-list span:nth-child(even) {
    padding-left: 16px;
    border-left: 1px solid #d7cfc5;
  }

  .builder-map-preview strong {
    color: #11110f;
  }

  .motion-studies-band {
    display: grid;
    grid-template-columns: minmax(320px, 0.82fr) minmax(0, 1.18fr);
    border-bottom: 1px solid #171717;
    background: #edf3ff;
  }

  .motion-studies-copy {
    display: grid;
    padding: 44px 36px;
    align-content: center;
    border-right: 1px solid #171717;
  }

  .motion-studies-copy h2 {
    max-width: 520px;
    margin-bottom: 20px;
    font-size: clamp(2.25rem, 4vw, 3.7rem);
  }

  .motion-studies-copy > p:not(.eyebrow) {
    max-width: 590px;
    color: #40444a;
  }

  .motion-principles {
    display: grid;
    grid-template-columns: 1fr 1fr;
    margin: 22px 0 26px;
    border-top: 1px solid #c8d3ea;
  }

  .motion-principles span {
    padding: 10px 0;
    border-bottom: 1px solid #c8d3ea;
    font-size: 0.78rem;
    font-weight: 800;
  }

  .motion-principles span:nth-child(even) {
    padding-left: 16px;
    border-left: 1px solid #c8d3ea;
  }

  .motion-studies-preview {
    display: grid;
    min-width: 0;
    padding: 32px;
    align-content: center;
    gap: 14px;
    color: #40444a;
    text-decoration: none;
  }

  .motion-studies-preview img {
    width: 100%;
    height: auto;
    min-width: 0;
    border: 1px solid #171717;
    border-radius: 6px;
  }

  .motion-studies-preview > span {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    font-size: 0.8rem;
  }

  .motion-studies-preview strong {
    color: #11110f;
  }

  .prototype-section {
    padding: 72px 40px;
    border-bottom: 1px solid #171717;
    background: #f6f7f8;
  }

  .prototype-intro {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 64px;
    align-items: end;
  }

  .prototype-intro h2 {
    max-width: 780px;
    margin-bottom: 0;
    font-size: clamp(2.8rem, 5vw, 4.8rem);
  }

  .prototype-intro > p {
    color: #4b4f55;
    font-size: 1.05rem;
  }

  .metric-strip,
  .decision-strip {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    margin-top: 46px;
    border-top: 1px solid #171717;
    border-bottom: 1px solid #171717;
  }

  .metric-strip > div,
  .decision-strip article {
    padding: 22px;
    border-right: 1px solid #171717;
  }

  .metric-strip > div:last-child,
  .decision-strip article:last-child {
    border-right: 0;
  }

  .metric-strip strong,
  .metric-strip span {
    display: block;
  }

  .metric-strip strong {
    color: #1652f0;
    font-size: 2.5rem;
  }

  .metric-strip span {
    margin-top: 8px;
    color: #62666c;
    font-size: 0.84rem;
  }

  .workbench-wrap {
    margin-top: 48px;
  }

  .decision-strip {
    margin-top: 36px;
  }

  .decision-strip article > span {
    color: #62666c;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.75rem;
  }

  .decision-strip h3 {
    margin: 24px 0 10px;
    font-size: 1.25rem;
  }

  .decision-strip p {
    color: #62666c;
    font-size: 0.88rem;
  }

  .experience-section {
    background: white;
  }

  .section-label .text-link {
    margin-top: 24px;
  }

  .timeline-grid {
    display: grid;
