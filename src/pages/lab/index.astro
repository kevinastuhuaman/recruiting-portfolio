---
import { ArrowUpRight, CodeXml } from "@lucide/astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { labArtifacts } from "../../data/site.js";

const previewTreatments = [
  { monogram: "IW", label: "Evidence → decision" },
  { monogram: "65", label: "Tools → product systems" },
  { monogram: "AW", label: "State → accountable action" },
  { monogram: "EC", label: "Regression → release gate" },
  { monogram: "HC", label: "Intent → human control" },
  { monogram: "MS", label: "Motion → product state" },
  { monogram: "EI", label: "Evidence → trusted interface" },
];
---

<BaseLayout
  title="AI Product Lab | Kevin Astuhuaman"
  description="Seven inspectable product studies covering grounded AI, evals, agent workflows, human control, motion, and enterprise interfaces."
  path="/lab/"
>
  <div class="lab-page">
    <header class="lab-hero">
      <p class="eyebrow">AI Product Lab</p>
      <h1>Product judgment you can use, test, and inspect.</h1>
      <p>Seven public experiments turn recurring AI product decisions into working interfaces. Each uses synthetic data and publishes a clear IP boundary, responsive tests, accessibility checks, and source.</p>
    </header>

    <section class="lab-grid" aria-label="Interactive product artifacts">
      {labArtifacts.map((artifact, index) => {
        const treatment = previewTreatments[index] ?? { monogram: "AI", label: "Interactive product study" };
        return (
        <article id={artifact.id} class:list={["lab-card", index === 0 && "lab-card-featured"]}>
          <a
            class:list={["lab-visual", `lab-preview-${index + 1}`]}
            href={artifact.live}
            aria-label={`Open ${artifact.name}`}
            data-lab-preview
          >
            <div class="lab-placeholder" aria-hidden="true">
              <span class="lab-placeholder-kicker">Interactive product study</span>
              <strong>{treatment.monogram}</strong>
              <span class="lab-placeholder-title">{artifact.name}</span>
              <span class="lab-placeholder-signal">{treatment.label}</span>
              <i></i><i></i>
            </div>
            {artifact.image ? (
              <img
                class="lab-preview-image"
                src={artifact.image}
                width="1200"
                height="630"
                loading={index === 0 ? "eager" : "lazy"}
                decoding="async"
                fetchpriority={index === 0 ? "high" : undefined}
                alt={`${artifact.name} interface preview`}
              />
            ) : (
              <div class="lab-monogram" aria-hidden="true"><span>{"monogram" in artifact ? artifact.monogram : "AI"}</span><i></i><i></i><i></i></div>
            )}
          </a>
          <div class="lab-copy">
            <span class="lab-number">0{index + 1}</span>
            <h2>{artifact.name}</h2>
            <p>{artifact.signal}</p>
            <div class="lab-actions">
              <a href={artifact.live}>Open study <ArrowUpRight aria-hidden="true" size={16} /></a>
              <a href={artifact.source}><CodeXml aria-hidden="true" size={16} /> Source</a>
            </div>
          </div>
        </article>
        );
      })}
    </section>

    <aside class="lab-boundary">
      <strong>Evidence boundary</strong>
      <p>These studies use synthetic data and original public interfaces. They demonstrate product thinking and implementation without publishing employer systems, Trackly user data, private infrastructure, or production authorization logic.</p>
    </aside>
  </div>

  <script>
    document.querySelectorAll<HTMLElement>("[data-lab-preview]").forEach((preview) => {
      const image = preview.querySelector<HTMLImageElement>(".lab-preview-image");
      if (!image) return;

      const reveal = () => {
        preview.classList.remove("is-loading", "has-error");
        preview.classList.add("is-ready");
      };
      const preserveFallback = () => {
        preview.classList.remove("is-loading", "is-ready");
        preview.classList.add("has-error");
      };

      const revealWhenDecoded = async () => {
        if (image.naturalWidth === 0) {
          preserveFallback();
          return;
        }
        try {
          await image.decode();
        } catch {
          if (image.naturalWidth === 0) {
            preserveFallback();
            return;
          }
        }
        reveal();
      };

      if (image.complete) {
        void revealWhenDecoded();
        return;
      }

      preview.classList.add("is-loading");
      image.addEventListener("load", () => void revealWhenDecoded(), { once: true });
      image.addEventListener("error", preserveFallback, { once: true });
    });
  </script>
</BaseLayout>

<style>
  .lab-page { max-width: 1280px; margin: 0 auto; padding: 84px 28px 120px; }
  .lab-hero { display: grid; grid-template-columns: minmax(0, 1.4fr) minmax(280px, .6fr); gap: 42px; align-items: end; padding: 56px 0 68px; border-bottom: 1px solid var(--ink); }
  .lab-hero .eyebrow { grid-column: 1 / -1; margin: 0; }
  .lab-hero h1 { margin: 0; max-width: 850px; font-size: clamp(3rem, 7vw, 6.8rem); line-height: .92; letter-spacing: -.055em; }
  .lab-hero > p:last-child { margin: 0; color: var(--muted); font-size: 1.06rem; line-height: 1.65; }
  .lab-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); border-left: 1px solid var(--ink); }
  .lab-card { min-width: 0; scroll-margin-top: 88px; border-right: 1px solid var(--ink); border-bottom: 1px solid var(--ink); background: #fff; }
  .lab-card-featured { grid-column: 1 / -1; display: grid; grid-template-columns: 1.3fr .7fr; }
  .lab-visual { position: relative; display: grid; min-width: 0; min-height: 0; aspect-ratio: 16 / 9; place-items: center; overflow: hidden; background: #141122; isolation: isolate; }
  .lab-preview-1, .lab-preview-5 { --preview-accent: #72d6ed; }
  .lab-preview-2, .lab-preview-6 { --preview-accent: #d8ff52; }
  .lab-preview-3, .lab-preview-7 { --preview-accent: #a57aff; }
  .lab-preview-4 { --preview-accent: #ffb86b; }
  .lab-placeholder { position: absolute; inset: 0; z-index: 1; display: grid; padding: clamp(22px, 4vw, 42px); grid-template: auto 1fr auto auto / 1fr; overflow: hidden; background: radial-gradient(circle at 82% 14%, color-mix(in srgb, var(--preview-accent) 24%, transparent), transparent 34%), #141122; color: #fff; transition: opacity .24s ease; }
  .lab-placeholder::before { position: absolute; inset: 0; background: linear-gradient(rgba(255,255,255,.055) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.055) 1px, transparent 1px); background-size: 38px 38px; content: ""; mask-image: linear-gradient(to bottom, #000, transparent 82%); }
  .lab-placeholder-kicker, .lab-placeholder-title, .lab-placeholder-signal, .lab-placeholder strong { position: relative; z-index: 2; }
  .lab-placeholder-kicker { color: color-mix(in srgb, var(--preview-accent) 84%, white); font: 700 .68rem/1 var(--font-mono); letter-spacing: .09em; text-transform: uppercase; }
  .lab-placeholder strong { align-self: center; font-size: clamp(4.6rem, 12vw, 9rem); line-height: .75; letter-spacing: -.09em; }
  .lab-placeholder-title { max-width: 28ch; margin-bottom: 7px; font-size: clamp(1rem, 2vw, 1.45rem); font-weight: 760; }
  .lab-placeholder-signal { color: rgba(255,255,255,.62); font-size: .78rem; }
  .lab-placeholder i { position: absolute; right: -9%; bottom: -34%; width: 58%; aspect-ratio: 1; border: 1px solid color-mix(in srgb, var(--preview-accent) 46%, transparent); border-radius: 50%; }
  .lab-placeholder i:last-child { right: 4%; bottom: -49%; width: 76%; opacity: .52; }
  .lab-visual img { position: relative; z-index: 2; display: block; width: 100%; height: 100%; min-height: 0; object-fit: contain; background: #141122; transition: transform .5s cubic-bezier(.2,.7,.2,1), opacity .24s ease; }
  .lab-visual.is-loading img, .lab-visual.has-error img { opacity: 0; }
  .lab-visual.is-ready .lab-placeholder { opacity: 0; pointer-events: none; }
  .lab-card:hover .lab-visual img { transform: scale(1.018); }
  .lab-copy { padding: 30px; }
  .lab-number { color: var(--accent); font: 700 .78rem/1 var(--font-mono); }
  .lab-copy h2 { margin: 46px 0 12px; font-size: clamp(1.7rem, 3vw, 2.6rem); letter-spacing: -.035em; }
  .lab-copy p { min-height: 3.5em; margin: 0; color: var(--muted); line-height: 1.55; }
  .lab-actions { display: flex; flex-wrap: wrap; gap: 20px; margin-top: 32px; }
  .lab-actions a { display: inline-flex; align-items: center; gap: 6px; font-weight: 700; text-decoration: none; }
  .lab-monogram { min-height: 290px; position: relative; display: grid; place-items: center; overflow: hidden; background: #141122; color: #fff; }
  .lab-monogram span { position: relative; z-index: 2; font-size: 5rem; font-weight: 800; letter-spacing: -.08em; }
  .lab-monogram i { position: absolute; width: 54%; aspect-ratio: 1; border: 1px solid rgba(255,255,255,.28); border-radius: 50%; }
  .lab-monogram i:nth-child(3) { width: 74%; }
  .lab-monogram i:nth-child(4) { width: 94%; }
  .lab-boundary { display: grid; grid-template-columns: 240px 1fr; gap: 28px; margin-top: 64px; padding: 26px 0; border-block: 1px solid var(--ink); }
  .lab-boundary p { margin: 0; max-width: 800px; color: var(--muted); }
  @media (max-width: 900px) {
    .lab-page { padding: 60px 18px 88px; }
    .lab-hero, .lab-card-featured, .lab-boundary { grid-template-columns: 1fr; }
    .lab-grid { grid-template-columns: 1fr; }
    .lab-card-featured { grid-column: auto; display: block; }
    .lab-visual { min-height: 0; }
    .lab-placeholder { padding: 22px; }
    .lab-placeholder strong { font-size: clamp(4.2rem, 22vw, 7rem); }
    .lab-copy h2 { margin-top: 28px; }
  }
  @media (prefers-reduced-motion: reduce) { .lab-visual img, .lab-placeholder { transition: none; } }
</style>
