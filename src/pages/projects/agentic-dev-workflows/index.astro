---
import { ArrowRight } from "@lucide/astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="AI-assisted product building | Kevin Astuhuaman"
  description="The maintained account of Kevin Astuhuaman's AI-assisted product workflow now lives inside the Trackly case study."
  path="/projects/agentic-dev-workflows/"
  noindex
>
  <section class="page-hero compatibility-hero">
    <div class="section-shell compatibility-grid">
      <div>
        <p class="eyebrow">AI-assisted product building</p>
        <h1>The workflow belongs beside the product evidence.</h1>
      </div>
      <div>
        <p class="lede">Kevin's current account of using coding agents, MCP, evaluation, observability, and human release judgment is part of the Trackly case study.</p>
        <a class="button button-light" href="/projects/trackly/#how-i-worked">Read how Kevin worked <ArrowRight aria-hidden="true" size={17} /></a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .compatibility-hero { min-height: 78svh; display: flex; align-items: center; background: #292642; }
  .compatibility-grid { display: grid; grid-template-columns: 1.15fr .85fr; gap: 72px; align-items: end; }
  .compatibility-grid h1 { max-width: 760px; }
  .compatibility-grid .button { margin-top: 28px; }
  @media (max-width: 760px) { .compatibility-grid { grid-template-columns: 1fr; gap: 28px; } }
</style>
