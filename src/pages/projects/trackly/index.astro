---
import { ArrowLeft, ArrowRight, ArrowUpRight, ExternalLink } from "@lucide/astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { links, routes } from "../../../data/site.js";
import { claimsById } from "../../../data/claims.js";

const inventory = claimsById["trackly-inventory"];
const route = routes.find((entry) => entry.path === "/projects/trackly/");
const inventoryMetrics = [
  { value: inventory.metrics?.[0]?.value, label: "active company career sites" },
  { value: inventory.metrics?.[1]?.value, label: "ATS and source types" },
  { value: inventory.metrics?.[2]?.value, label: "active jobs" },
];
---

<BaseLayout
  title="Trackly case study | Kevin Astuhuaman"
  description="How Kevin Astuhuaman built Trackly around direct career-page signal, product quality, explainable matching, agent-ready interfaces, and a human-reviewed browser-agent harness."
  path="/projects/trackly/"
  pageType="article"
  about="Trackly"
  modified={route?.modified}
>
  <header class="page-hero trackly-hero">
    <div class="section-shell">
      <p class="eyebrow">Hands-on AI product building | 2026-present</p>
      <h1>A job-search product built around earlier signal and earned trust.</h1>
      <p class="lede">
        I started Trackly during my MBA recruiting cycle because job boards were too slow. The product now monitors direct company career pages and turns that changing data into matches, explanations, alerts, and agent-ready workflows.
      </p>
      <div class="case-meta">
        <span><strong>Role:</strong> AI Product Manager and builder</span>
        <span><strong>State:</strong> Live public product</span>
        <span><strong>Surfaces:</strong> Web, iOS, macOS, CLI, MCP</span>
      </div>
      <div class="button-row hero-actions">
        <a class="button button-light" href={links.trackly}>Open Trackly <ArrowUpRight aria-hidden="true" size={17} /></a>
        <a class="button button-outline-light" href={links.appStore}>App Store <ExternalLink aria-hidden="true" size={16} /></a>
        <a class="button button-outline-light" href={links.tracklyCli}>CLI + MCP <ExternalLink aria-hidden="true" size={16} /></a>
      </div>
    </div>
  </header>

  <article class="article-shell">
    <p class="eyebrow">The product tension</p>
    <h2>The best role can be invisible at the moment it matters.</h2>
    <p>
      Job boards optimize for aggregation and distribution. A candidate optimizes for timing and relevance. During recruiting, I kept finding roles on company sites before they appeared in my feeds. That gap became the wedge: monitor the source directly, then make the signal reliable enough to act on.
    </p>

    <div class="metric-row" aria-label="Current Trackly public inventory">
      {inventoryMetrics.map((metric) => <div class="metric"><strong>{metric.value}</strong><span>{metric.label}</span></div>)}
    </div>

    <figure class="trackly-film">
      <video
        data-trackly-film
        controls
        loop
        muted
        playsinline
        preload="metadata"
        poster="/assets/trackly-demo-poster.webp"
        aria-label="Short Trackly product film"
      >
        <source src="/assets/trackly-demo-preview.mp4" type="video/mp4" />
      </video>
      <figcaption>
        <span><strong>18-second product film.</strong> Real Trackly product motion, from direct signal to native delivery.</span>
        <a href="https://youtu.be/gGQ1NOzykDo">Watch the full demo <ArrowUpRight aria-hidden="true" size={15} /></a>
      </figcaption>
    </figure>

    <figure class="artifact-frame">
      <img
        src="/assets/trackly-home.webp"
        width="1440"
        height="1000"
        alt="Trackly public homepage showing monitored companies and job inventory"
      />
      <figcaption class="artifact-caption">
        <span>Decision proved: own the source instead of waiting for a downstream feed.</span>
        <span>Live public product capture</span>
      </figcaption>
    </figure>

    <section class="case-snapshot" aria-labelledby="snapshot-title">
      <div>
        <p class="eyebrow">60-second read</p>
        <h2 id="snapshot-title">What Trackly proves</h2>
      </div>
      <ul>
        <li><strong>Found the wedge</strong><span>Direct career-page signal arrives before downstream job boards.</span></li>
        <li><strong>Built the quality system</strong><span>Freshness, deduplication, classification, false-zero recovery, and explainable matches.</span></li>
        <li><strong>Shipped the product</strong><span>One product model extended across web, native apps, agent tools, chat, and voice.</span></li>
      </ul>
    </section>

    <section class="surface-proof" aria-labelledby="surface-proof-title">
      <header class="surface-proof-header">
        <div>
          <p class="eyebrow">Selected product surfaces</p>
          <h2 id="surface-proof-title">One product, designed for different moments.</h2>
        </div>
        <div class="surface-gallery-controls" aria-label="Product surface navigation">
          <p class="surface-count"><strong data-surface-current>01</strong><span aria-hidden="true"> / </span><span>05</span><span class="sr-only"> product surfaces</span></p>
          <div class="surface-arrow-controls">
            <button type="button" data-surface-previous aria-controls="trackly-surface-rail" aria-label="Show previous product surface" disabled>
              <ArrowLeft aria-hidden="true" size={18} />
            </button>
            <button type="button" data-surface-next aria-controls="trackly-surface-rail" aria-label="Show next product surface">
              <ArrowRight aria-hidden="true" size={18} />
            </button>
          </div>
        </div>
      </header>
      <div id="trackly-surface-rail" class="surface-rail" tabindex="0" role="region" aria-label="Five Trackly product surfaces; use the arrow controls or scroll horizontally" data-surface-rail>
        <figure class="surface-web" data-surface-card>
          <div class="surface-media"><img src="/assets/trackly-home.webp" width="1440" height="1000" loading="lazy" decoding="async" alt="Trackly web product showing monitored companies, job inventory, and role tracking" /></div>
          <figcaption><strong>Web</strong><span>Research the market and manage signal</span></figcaption>
        </figure>
        <figure class="surface-ios" data-surface-card>
          <div class="surface-media"><img src="/assets/trackly-app-store.webp" width="1284" height="1291" loading="lazy" decoding="async" alt="Trackly iOS App Store product page" /></div>
          <figcaption><strong>iOS</strong><span>Act while a role is new</span></figcaption>
        </figure>
        <figure class="surface-macos" data-surface-card>
          <div class="surface-media"><img src="/assets/trackly-macos-appstore.webp" width="1840" height="1140" loading="lazy" decoding="async" alt="Trackly macOS App Store product page" /></div>
          <figcaption><strong>macOS</strong><span>Keyboard-first triage</span></figcaption>
        </figure>
        <figure class="surface-cli" data-surface-card>
          <div class="surface-media">
            <div class="surface-terminal-pane"><img src="/assets/trackly-cli.webp" width="720" height="720" loading="lazy" decoding="async" alt="Trackly command-line search results" /></div>
            <div class="surface-mcp-pane"><img src="/assets/trackly-mcp.webp" width="720" height="720" loading="lazy" decoding="async" alt="Trackly MCP server configuration" /></div>
          </div>
          <figcaption><strong>CLI + MCP</strong><span>Bring the signal into agent workflows</span></figcaption>
        </figure>
        <figure class="surface-conversation" data-surface-card>
          <div class="surface-media">
            <div class="surface-chat-preview" aria-hidden="true">
              <span>CHAT</span>
              <i></i><i></i><i></i>
              <strong>Grounded answers</strong>
            </div>
            <div class="surface-voice-preview">
              <img src="/assets/portfolio-orb-static.png" width="600" height="602" loading="lazy" decoding="async" alt="Metal orb representing Trackly's realtime voice interface" />
              <span aria-hidden="true">VOICE</span>
            </div>
          </div>
          <figcaption><strong>Chat + Voice</strong><span>Ask through the interface that fits the moment</span></figcaption>
        </figure>
      </div>
      <nav class="surface-progress" aria-label="Choose a Trackly product surface">
        {['Web', 'iOS', 'macOS', 'CLI and MCP', 'Chat and Voice'].map((label, index) => (
          <button type="button" data-surface-target={index} aria-label={`Show ${label}`} aria-current={index === 0 ? 'true' : undefined}><span></span></button>
        ))}
      </nav>
    </section>

    <details class="case-depth" data-case-depth>
      <summary><span>Explore the full product decision record</span><small>System quality, evals, failure recovery, and human control</small></summary>
      <div class="case-depth-content">

    <h2>The product system</h2>
    <p>
      The interface starts after the difficult part. Career pages change structure, repost old jobs, omit dates, duplicate locations, and sometimes return a valid empty page. Trackly treats source health, normalization, classification, freshness, and explanation as one product-quality system.
    </p>

    <figure class="system-artifact" aria-labelledby="system-title">
      <figcaption id="system-title"><span>A public-safe reconstruction of the Trackly product loop</span></figcaption>
      <ol>
        <li><strong>Observe</strong><span>Direct career pages and ATS sources</span></li>
        <li><strong>Normalize</strong><span>Hydrate fields, merge duplicates, resolve location</span></li>
        <li><strong>Judge quality</strong><span>Freshness guards, false-zero canaries, classifier evals</span></li>
        <li><strong>Match</strong><span>Weighted fit with an explanation, not a black-box score</span></li>
        <li><strong>Deliver</strong><span>Web, native apps, CLI, MCP, chat, and voice</span></li>
      </ol>
      <p>Every delivery surface uses the same underlying job and quality model.</p>
    </figure>

    <h2>Three decisions shaped the product.</h2>
    <dl class="decision-list">
      <div class="decision">
        <dt>1. Direct signal first</dt>
        <dd>
          <dl class="decision-anatomy">
            <div class="decision-option decision-option-choice"><dt>Choice</dt><dd>Build source monitoring before building a polished application tracker.</dd></div>
            <div class="decision-option decision-option-rejected"><dt>Rejected</dt><dd>Another job-board search layer.</dd></div>
            <div class="decision-option decision-option-why"><dt>Why</dt><dd>Earlier signal was the unique user advantage and the hardest capability to copy credibly.</dd></div>
          </dl>
        </dd>
      </div>
      <div class="decision">
        <dt>2. Quality is visible</dt>
        <dd>
          <dl class="decision-anatomy">
            <div class="decision-option decision-option-choice"><dt>Choice</dt><dd>Expose match reasoning and operate explicit failure guards.</dd></div>
            <div class="decision-option decision-option-rejected"><dt>Rejected</dt><dd>Hide uncertainty behind a single AI score.</dd></div>
            <div class="decision-option decision-option-why"><dt>Why</dt><dd>A confident wrong recommendation costs the user time and erodes trust faster than a cautious explanation.</dd></div>
          </dl>
        </dd>
      </div>
      <div class="decision">
        <dt>3. Shared system, native behavior</dt>
        <dd>
          <dl class="decision-anatomy">
            <div class="decision-option decision-option-choice"><dt>Choice</dt><dd>Keep product rules in shared services while designing each surface for its context.</dd></div>
            <div class="decision-option decision-option-rejected"><dt>Rejected</dt><dd>Wrap the web product everywhere.</dd></div>
            <div class="decision-option decision-option-why"><dt>Why</dt><dd>Alerts, keyboard workflows, agent calls, and mobile triage each need a different interaction model.</dd></div>
          </dl>
        </dd>
      </div>
    </dl>

    <h2>An eval is a release decision, not a model demo.</h2>
    <p>
      Trackly classifies job function, seniority, region, sponsorship, salary, and experience signals. The product question is not whether a model can return a label. It is whether a label is safe to use for ranking, filtering, and alerts.
    </p>

    <div class="eval-artifact" aria-label="Example Trackly classification review">
      <div class="eval-input">
        <span>Synthetic public example</span>
        <h3>Senior Product Manager, AI Platform</h3>
        <p>Own model-evaluation infrastructure, API reliability, and enterprise developer workflows.</p>
      </div>
      <div class="eval-output">
        <div><span>Function</span><strong>Product management</strong></div>
        <div><span>Domain</span><strong>AI platform</strong></div>
        <div><span>Level</span><strong>Senior</strong></div>
        <div><span>Release gate</span><strong>Review disagreement before backfill</strong></div>
      </div>
    </div>
    <p class="artifact-note">
      The example is synthetic. It demonstrates the review logic without exposing a user's job history or private model traces.
    </p>

    <h2>The failure mode that changed the roadmap</h2>
    <p>
      A source can return zero jobs and still look technically healthy. Treating that response as success silently deletes opportunity from the product. Trackly added false-zero canaries and source-health checks so a suspicious empty result becomes an incident to inspect, not a clean update to publish.
    </p>
    <div class="failure-sequence" role="list" aria-label="False-zero recovery sequence">
      <div role="listitem"><span>Signal</span><strong>Source unexpectedly returns zero jobs</strong></div>
      <div role="listitem"><span>Guard</span><strong>Compare with historical volume and page health</strong></div>
      <div role="listitem"><span>Action</span><strong>Quarantine the update and alert the operator</strong></div>
      <div role="listitem"><span>User result</span><strong>Previously valid jobs remain available until the source is fixed</strong></div>
    </div>

    <h2>One product, interface-specific jobs</h2>
    <div class="surface-layout">
      <figure class="artifact-frame surface-image">
        <img
          src="/assets/trackly-app-store.webp"
          width="1284"
          height="1291"
          alt="Trackly App Store product page"
        />
        <figcaption class="artifact-caption"><span>Native distribution</span><span>Public App Store artifact</span></figcaption>
      </figure>
      <ul class="surface-list">
        <li><strong>Web</strong><span>Research, compare, manage, and explain.</span></li>
        <li><strong>iOS</strong><span>Act on a new role while it is still new.</span></li>
        <li><strong>macOS</strong><span>Use keyboard-first workflows beside the application process.</span></li>
        <li><strong>CLI + MCP</strong><span>Bring the same job signal into an agent or developer workflow.</span></li>
        <li><strong>Chat + voice</strong><span>Ask, confirm, and take structured actions through conversational interfaces.</span></li>
      </ul>
    </div>

    <section class="browser-harness-section" aria-labelledby="browser-harness-title">
      <p class="eyebrow">Recent computer-use experiment | July 2026</p>
      <h2 id="browser-harness-title">A browser agent becomes useful when the product defines where autonomy ends.</h2>
      <p>
        Within days of GPT-5.6 reaching Codex, I turned Trackly's saved-job workflow into a domain-specific computer-use harness. Trackly supplies the selected roles and user context through its CLI and MCP server. The harness adds ATS-specific mechanics, form-integrity checks, and recovery rules. Codex then uses Chrome to prepare each application.
      </p>
      <p>
        The key product decision is the stopping point. The workflow can enter reusable facts and prepare draft responses, but it pauses before submission. Subjective answers, salary, sponsorship, and any unresolved field remain visible to the user. Submission requires a fresh instruction tied to that job, and any edit, navigation, reload, or reconnect invalidates the earlier approval.
      </p>

      <figure class="browser-harness" aria-labelledby="browser-harness-caption">
        <figcaption id="browser-harness-caption">The working control loop, shown without private application data</figcaption>
        <ol>
          <li><span>01</span><strong>Select</strong><p>The user saves the work worth completing in Trackly.</p></li>
          <li><span>02</span><strong>Ground</strong><p>MCP supplies the job, profile context, and allowed answers.</p></li>
          <li><span>03</span><strong>Prepare</strong><p>Codex controls Chrome using ATS-specific interaction rules.</p></li>
          <li><span>04</span><strong>Verify</strong><p>The harness checks committed form state, errors, and unknowns.</p></li>
          <li><span>05</span><strong>Review</strong><p>A person inspects every consequential answer and edit.</p></li>
          <li><span>06</span><strong>Authorize</strong><p>Only a fresh, item-specific instruction can allow submission.</p></li>
        </ol>
      </figure>

      <div class="autonomy-boundary" aria-label="Browser-agent autonomy boundary">
        <div>
          <span>Agent may</span>
          <strong>Fetch approved context, upload the resume, fill known fields, draft answers, and validate the form.</strong>
        </div>
        <div>
          <span>Agent must show</span>
          <strong>Subjective responses, salary, sponsorship, demographic choices, missing facts, and validation uncertainty.</strong>
        </div>
        <div>
          <span>Agent may not</span>
          <strong>Submit without fresh approval, invent facts, bypass security checks, or treat visible text as proof that the form accepted a value.</strong>
        </div>
      </div>

      <h3>Recruiting is one instance of a broader product pattern.</h3>
      <div class="transfer-grid">
        <article>
          <span>Financial operations</span>
          <h4>Prepare high-volume forms from approved records.</h4>
          <p>The agent handles repetitive browser entry; an operator reviews regulated or consequential fields before filing.</p>
        </article>
        <article>
          <span>Sales and CRM</span>
          <h4>Carry account context into portals without losing judgment.</h4>
          <p>The agent can populate structured fields and draft notes while the account owner approves external messages and commitments.</p>
        </article>
        <article>
          <span>Legacy enterprise workflows</span>
          <h4>Bridge systems when the last mile has no reliable API.</h4>
          <p>A domain harness turns a general browser agent into a bounded operator with explicit rules, exceptions, recovery, and audit evidence.</p>
        </article>
      </div>

      <p class="artifact-note browser-source">
        Current state: a working personal workflow across supported ATS forms, described here as a product experiment rather than autonomous submission. Public references: <a href={links.tracklyCli}>Trackly CLI and MCP</a>, <a href={links.humanControlPlane}>the interactive Human Control Plane</a>, and <a href={links.gpt56}>OpenAI's July 9, 2026 GPT-5.6 announcement</a>.
      </p>
    </section>

    <h2 id="how-i-worked">How I worked</h2>
    <p>
      I owned the product problem, prioritization, interaction decisions, quality thresholds, release decisions, and day-to-day operation. I also wrote and reviewed implementation across the stack. AI coding agents accelerated research, implementation, testing, and review; they did not decide what the product should promise or what evidence was good enough to ship.
    </p>
    <p>
      That division matters. Trackly is evidence that I can work close to the system without confusing code output with product judgment.
    </p>

    <h2>What I would change next</h2>
    <p>
      I would narrow the default product around a smaller number of repeatable decisions: which opportunities deserve attention now, why the match is credible, and what action moves the search forward. New surfaces earn their place only when they improve one of those decisions.
    </p>
      </div>
    </details>

    <div class="button-row final-actions">
      <a class="button button-dark" href={links.trackly}>Open Trackly <ArrowUpRight aria-hidden="true" size={17} /></a>
      <a class="button" href="/resume/">View resume</a>
      <a class="button" href="/contact/">Contact Kevin</a>
    </div>
  </article>

  <script>
    const openDeepLinkedEvidence = () => {
      const targetId = window.location.hash.slice(1);
      const target = targetId ? document.getElementById(targetId) : null;
      const disclosure = target?.closest<HTMLDetailsElement>("details[data-case-depth]");
      if (disclosure) disclosure.open = true;
    };
    openDeepLinkedEvidence();
    window.addEventListener("hashchange", openDeepLinkedEvidence);
  </script>

  <script>
    const rail = document.querySelector<HTMLElement>("[data-surface-rail]");
    const cards = Array.from(document.querySelectorAll<HTMLElement>("[data-surface-card]"));
    const current = document.querySelector<HTMLElement>("[data-surface-current]");
    const previous = document.querySelector<HTMLButtonElement>("[data-surface-previous]");
    const next = document.querySelector<HTMLButtonElement>("[data-surface-next]");
    const targets = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-surface-target]"));
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
    let activeSurface = 0;
    let surfaceFrame = 0;

    const setActiveSurface = (index: number) => {
      activeSurface = Math.max(0, Math.min(cards.length - 1, index));
      if (current) current.textContent = String(activeSurface + 1).padStart(2, "0");
      if (previous) previous.disabled = activeSurface === 0;
      if (next) next.disabled = activeSurface === cards.length - 1;
      targets.forEach((target, targetIndex) => {
        if (targetIndex === activeSurface) target.setAttribute("aria-current", "true");
        else target.removeAttribute("aria-current");
      });
    };

    const scrollToSurface = (index: number) => {
      const card = cards[index];
      if (!rail || !card) return;
      rail.scrollTo({
        left: card.offsetLeft - rail.offsetLeft,
        behavior: reducedMotion.matches ? "auto" : "smooth",
      });
      setActiveSurface(index);
    };

    const updateSurfaceFromScroll = () => {
      if (!rail || cards.length === 0) return;
      const railLeft = rail.getBoundingClientRect().left;
      const closest = cards.reduce((best, card, index) => {
        const distance = Math.abs(card.getBoundingClientRect().left - railLeft);
        return distance < best.distance ? { index, distance } : best;
      }, { index: 0, distance: Number.POSITIVE_INFINITY });
      setActiveSurface(closest.index);
    };

    previous?.addEventListener("click", () => scrollToSurface(activeSurface - 1));
    next?.addEventListener("click", () => scrollToSurface(activeSurface + 1));
    targets.forEach((target) => target.addEventListener("click", () => scrollToSurface(Number(target.dataset.surfaceTarget))));
    rail?.addEventListener("scroll", () => {
      window.cancelAnimationFrame(surfaceFrame);
      surfaceFrame = window.requestAnimationFrame(updateSurfaceFromScroll);
    }, { passive: true });
    window.addEventListener("resize", updateSurfaceFromScroll, { passive: true });
    setActiveSurface(0);
  </script>

  <script>
    const film = document.querySelector<HTMLVideoElement>("[data-trackly-film]");
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
    if (film && !reduceMotion.matches && "IntersectionObserver" in window) {
      const observer = new IntersectionObserver(([entry]) => {
        if (entry?.isIntersecting) void film.play().catch(() => undefined);
        else film.pause();
      }, { threshold: 0.45 });
      observer.observe(film);
    }
  </script>
</BaseLayout>

